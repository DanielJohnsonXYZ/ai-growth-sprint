---
import BaseLayout from "../layouts/BaseLayout.astro";
import { guides, postLaunchArticles } from "../data/site";
---

<BaseLayout
  title="Resources"
  description="Industry-specific guides and workflow examples for UK SME teams using AI."
>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Resources</p>
      <h1>Guides, examples, and practical advice.</h1>
      <p>
        Start with one of the practical guides, then use the industry and
        workflow examples to decide which tasks are worth training first.
      </p>
      <a class="button" href="/contact/">Book a free call</a>
    </div>
    <aside class="panel panel-pad">
      <h2>Start with business results.</h2>
      <p class="lead">Each guide is written around time saved, work improved, and approval staying human.</p>
    </aside>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Free guides</p>
      <h2>Useful before a workshop.</h2>
    </div>
    <div class="grid grid-3">
      {guides.map((guide) => (
        <article class="card card-interactive">
          <p class="eyebrow">{guide.audience}</p>
          <h3>{guide.title}</h3>
          <p>{guide.intro}</p>
          <a href={`/guides/${guide.slug}/`}>Read guide</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Coming soon</p>
      <h2>Articles in progress.</h2>
    </div>
    <div class="grid grid-3">
      {postLaunchArticles.map((title, index) => (
        <article class="card">
          <span class="tag pending">Coming soon</span>
          <h3>{title}</h3>
          <p>{index < 3 ? "One of the first articles we're publishing." : "Coming after the first batch."}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
