---
import BaseLayout from "../layouts/BaseLayout.astro";
import { postLaunchArticles } from "../data/site";
---

<BaseLayout
  title="Resources"
  description="Industry-specific guides and workflow examples for UK SME teams using AI."
>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Resources</p>
      <h1>Guides, examples, and practical advice.</h1>
      <p>
        Industry-specific articles and workflow guides are being published
        on a rolling basis. Starting with construction, accounting, and
        property — the industries we work with most.
      </p>
      <a class="button" href="/contact/">Book a free call</a>
    </div>
    <aside class="panel panel-pad">
      <h2>New articles coming regularly.</h2>
      <p class="lead">Practical stuff based on real work, not generic AI advice.</p>
    </aside>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Coming soon</p>
      <h2>Articles in progress.</h2>
    </div>
    <div class="grid grid-3">
      {postLaunchArticles.map((title, index) => (
        <article class="card">
          <span class="tag pending">Coming soon</span>
          <h3>{title}</h3>
          <p>{index < 3 ? "One of the first articles we're publishing." : "Coming after the first batch."}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
