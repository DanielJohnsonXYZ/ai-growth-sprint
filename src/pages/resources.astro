---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Free AI Resources for SMEs"
  description="Useful content to help UK business owners make smarter AI decisions. Guides, templates, and practical advice."
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Resources</p>
      <h1>Free AI Resources for SMEs</h1>
      <p>Useful content to help business owners make smarter AI decisions.</p>
      <a class="button" href="/contact/" data-cta="resources-hero-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Practical, not theoretical</p>
      <h2>Resources written for business owners, not developers.</h2>
      <p class="lead">No technical jargon. No product pitches. Just useful guidance on how to use AI in your business.</p>
    </aside>
  </section>

  <!-- RESOURCES LIST -->
  <section class="section">
    <div class="grid grid-3">
      {([
        ["Guide", "AI for SMEs in 2026", "What actually works for small and medium businesses right now — practical tools, common mistakes, and where to start.", "resource-smes-2026", null],
        ["Guide", "How to Train Your Team on AI", "A practical framework for getting your team using AI confidently without chaos or confusion.", "resource-train-team", null],
        ["Guide", "Best AI Tools for Accountants", "A breakdown of which tools actually save time in accounting workflows and which ones to avoid.", "resource-accountants", null],
        ["Template", "AI Policy Template for Small Businesses", "A ready-to-use AI usage policy you can adapt for your team — covering data, approval, and acceptable use. Read the full sample online or request by email.", "resource-policy", "/ai-policy-template/"],
        ["Guide", "AI Adoption Checklist for UK SMEs", "Step-by-step checklist for adopting AI in your business — where to start and what to prioritise.", "resource-checklist", null],
      ] as const).map(([type, title, body, id, readOnlineHref]) => (
        <article class="card card-interactive lead-magnet-panel">
          <p class="eyebrow">{type}</p>
          <h3>{title}</h3>
          <p>{body}</p>
          {readOnlineHref ? (
            <p class="resource-online-link">
              <a class="text-link" href={readOnlineHref} data-cta={`resources-read-${id}`}>
                Read the sample policy online
              </a>
            </p>
          ) : null}
          <form data-lead-magnet={id} class="lead-magnet-form">
            <input type="email" placeholder="Your email" required class="lead-magnet-input" />
            <button class="button button-small" type="submit">{type === "Template" ? "Email me a copy" : "Get guide"}</button>
          </form>
        </article>
      ))}
    </div>
  </section>

  <!-- WANT MORE -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <p class="eyebrow">Want personalised advice?</p>
        <h2>Resources are a starting point. A discovery call goes further.</h2>
        <p>Book a free call and we'll tell you exactly where AI fits your business — not a generic answer.</p>
      </div>
      <div class="button-row">
        <a class="button" href="/contact/" data-cta="resources-cta-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
        <a class="button button-secondary" href="/services/" data-cta="resources-services">See services</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .resource-online-link {
    margin: 0.35rem 0 0.65rem;
  }
  .resource-online-link .text-link {
    color: var(--accent, #0f766e);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>

<script>
  document.querySelectorAll('.lead-magnet-form').forEach(form => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const email = form.querySelector('input[type="email"]')?.value;
      if (!email) return;
      const resourceId = form.dataset.leadMagnet;
      const subject = `Resource request: ${resourceId}`;
      const body = `Email: ${email}\n\nPlease send me the resource: ${resourceId}`;
      window.location.href = `mailto:hello@humanapprovedai.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  });
</script>
