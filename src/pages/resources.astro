---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const posts = [
  {
    category: "How-To Guide",
    title: "How to write AI prompts that actually work for your business",
    excerpt: "Most business owners get poor results from AI because they ask the wrong questions. Here's a simple framework that changes everything.",
    readTime: "5 min read",
    date: "May 2026",
    href: "#",
    featured: true,
  },
  {
    category: "Tools & Reviews",
    title: "The 10 AI tools every small business should know in 2026",
    excerpt: "An honest, jargon-free guide to the tools worth your attention — and the ones that aren't worth the subscription fee.",
    readTime: "8 min read",
    date: "April 2026",
    href: "#",
  },
  {
    category: "Industry Spotlight",
    title: "AI for hospitality: 5 things your competitors are doing right now",
    excerpt: "Restaurants, hotels, and bars are quietly using AI to reduce admin, respond faster, and keep customers coming back. Here's what they're doing.",
    readTime: "6 min read",
    date: "April 2026",
    href: "#",
  },
  {
    category: "Strategy",
    title: "Why your AI tools aren't working — and how to fix it",
    excerpt: "The problem usually isn't the tool. It's the lack of a clear workflow, a prompt that doesn't work, or a team that doesn't know what to do with it.",
    readTime: "7 min read",
    date: "March 2026",
    href: "#",
  },
  {
    category: "How-To Guide",
    title: "Using AI for customer emails: a step-by-step guide for small business owners",
    excerpt: "Cut your email response time by 60% without losing the human tone your customers expect. Here's exactly how to set it up.",
    readTime: "9 min read",
    date: "March 2026",
    href: "#",
  },
  {
    category: "Tools & Reviews",
    title: "ChatGPT vs Microsoft Copilot: which is right for your business?",
    excerpt: "The honest comparison nobody else will give you — because the right answer depends entirely on how your team already works.",
    readTime: "6 min read",
    date: "February 2026",
    href: "#",
  },
];
---

<Layout
  title="Resources & Blog"
  description="Practical AI guidance for small business owners — no jargon, no hype. Real tips, tool reviews, and how-to guides to help you get started."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="pt-16 pb-14 bg-white border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl">
          <p class="text-brand-600 font-semibold text-sm uppercase tracking-wider mb-3">Resources</p>
          <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-5">
            Practical AI guidance for business owners
          </h1>
          <p class="text-gray-500 text-lg leading-relaxed">
            No jargon, no hype. Just real, actionable advice for small business owners who want to understand and use AI — without needing a tech background.
          </p>
        </div>
      </div>
    </section>

    <!-- Lead magnet -->
    <section class="py-10 bg-brand-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 reveal">
          <div>
            <p class="text-brand-300 text-sm font-semibold uppercase tracking-wider mb-1">Free download</p>
            <h2 class="text-xl font-bold text-white">The 10 AI Tools Every Small Business Should Know in 2026</h2>
            <p class="text-brand-200 text-sm mt-1">A plain-English guide to the tools that are actually worth your time — and how to use them.</p>
          </div>
          <form class="flex flex-col sm:flex-row gap-3 flex-shrink-0 w-full md:w-auto" onsubmit="return false;">
            <input
              type="email"
              placeholder="Your email address"
              class="px-4 py-3 rounded-xl text-sm border-0 focus:ring-2 focus:ring-brand-300 min-w-60 w-full sm:w-auto"
              required
            />
            <button
              type="submit"
              class="px-5 py-3 bg-white text-brand-700 font-semibold rounded-xl hover:bg-brand-50 transition-colors text-sm whitespace-nowrap"
            >
              Get the free guide
            </button>
          </form>
        </div>
      </div>
    </section>

    <!-- Blog posts -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Featured post -->
        <div class="mb-10">
          <div class="bg-white rounded-3xl border border-gray-200 overflow-hidden shadow-sm reveal">
            <div class="grid grid-cols-1 lg:grid-cols-2">
              <div class="bg-brand-50 flex items-center justify-center p-12 min-h-48">
                <div class="text-center">
                  <div class="w-16 h-16 rounded-2xl bg-brand-200 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-brand-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                    </svg>
                  </div>
                  <span class="text-brand-600 text-sm font-semibold">Featured Article</span>
                </div>
              </div>
              <div class="p-8 lg:p-10">
                <span class="inline-block px-3 py-1 bg-brand-100 text-brand-700 text-xs font-semibold rounded-full mb-4">{posts[0].category}</span>
                <h2 class="text-2xl font-bold text-gray-900 mb-3">{posts[0].title}</h2>
                <p class="text-gray-500 leading-relaxed mb-5">{posts[0].excerpt}</p>
                <div class="flex items-center justify-between">
                  <span class="text-gray-400 text-sm">{posts[0].readTime} · {posts[0].date}</span>
                  <a href={posts[0].href} class="inline-flex items-center gap-1.5 text-brand-600 font-semibold text-sm hover:gap-2.5 transition-all">
                    Read article
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Post grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.slice(1).map((post, i) => (
            <article class={`reveal reveal-delay-${i + 1} bg-white rounded-2xl border border-gray-200 p-7 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all`}>
              <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded-full mb-4">{post.category}</span>
              <h3 class="font-bold text-gray-900 mb-3 leading-snug">{post.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed mb-5">{post.excerpt}</p>
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <span class="text-gray-400 text-xs">{post.readTime} · {post.date}</span>
                <a href={post.href} class="text-brand-600 font-semibold text-sm hover:text-brand-700 transition-colors">
                  Read →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-14 bg-white border-t border-gray-100">
      <div class="max-w-2xl mx-auto px-4 text-center reveal">
        <p class="text-gray-500 mb-5">Ready to go beyond reading and actually start using AI in your business?</p>
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3.5 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors shadow-sm">
          Book a Free Discovery Call
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
