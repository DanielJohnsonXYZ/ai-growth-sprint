---
import BaseLayout from "../layouts/BaseLayout.astro";
import { postLaunchArticles } from "../data/site";
---

<BaseLayout
  title="Resources"
  description="Post-launch resource hub for AI Growth Sprint industry articles and workflow guides."
>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Resources</p>
      <h1>Guides, examples, and practical AI advice.</h1>
      <p>
        Industry-specific articles and workflow guides are being published
        on a rolling basis. Check back regularly for new content.
      </p>
      <a class="button" href="/contact/">Book a free 15-minute call</a>
    </div>
    <aside class="panel panel-pad">
      <h2>New articles every month.</h2>
      <p class="lead">Starting with construction, accounting, and property — the industries where we have the most proof.</p>
    </aside>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Coming soon</p>
      <h2>Articles in progress.</h2>
    </div>
    <div class="grid grid-3">
      {postLaunchArticles.map((title, index) => (
        <article class="card">
          <span class="tag pending">Post-launch</span>
          <h3>{title}</h3>
          <p>{index < 3 ? "Priority article for first outreach sectors." : "Roll out after the first proof and search data."}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
