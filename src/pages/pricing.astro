---
import BaseLayout from "../layouts/BaseLayout.astro";
import { packages, SITE } from "../data/site";
---

<BaseLayout
  title="Pricing"
  description={`Compare ${SITE.name} options for safe, practical AI adoption that sticks.`}
>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Pricing</p>
      <h1>Three packages. One clear next step.</h1>
      <p>
        Choose by team size, customization needs, and how much support you want
        after the first session. Every option includes practical workflows,
        approval rules, and a free 15-minute fit call first.
      </p>
      <a class="button" href="/contact/">Book a free 15-minute call</a>
    </div>
    <aside class="panel panel-pad">
      <h2>Buyer fit matters.</h2>
      <p class="lead">The call helps confirm which option makes sense before anyone commits budget.</p>
    </aside>
  </section>

  <section class="section">
    <div class="grid grid-3">
      {packages.map((item, index) => (
        <article class={index === 0 ? "card pricing-card recommended" : "card pricing-card"}>
          {index === 0 && <span class="badge">Most teams start here</span>}
          <p class="eyebrow">Package {index + 1}</p>
          <h2>{item.name}</h2>
          <strong class="price">{item.price}</strong>
          <p>{item.fit}</p>
          <ul class="checklist">
            {item.includes.map((line) => <li>{line}</li>)}
          </ul>
          <a href="/contact/">Discuss this option</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight chapter">
    <div class="panel panel-pad">
      <div class="section-header">
        <p class="eyebrow">Which option is right?</p>
        <h2>Use the depth of support as the deciding factor.</h2>
      </div>
      <div class="grid grid-3">
        <article class="card"><strong>Fastest adoption</strong><p>Choose Team Workshop when a whole team needs a shared, safe way of working.</p></article>
        <article class="card"><strong>Lowest commitment</strong><p>Choose Open Cohort when the buyer is smaller or not ready for a private session.</p></article>
        <article class="card"><strong>Deepest implementation</strong><p>Choose 4-Week Programme when workflows need repetition, review, and coaching.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="panel panel-pad trust-panel">
      <p class="eyebrow">Need confidence first?</p>
      <h2>Check the approval boundaries before choosing a package.</h2>
      <p class="lead">See how the workshop handles sensitive data, hallucination risk, and human sign-off before anything reaches a client.</p>
      <div class="button-row" style="margin-top: 24px">
        <a class="button" href="/trust-security/">Read trust rules</a>
        <a class="button button-secondary" href="/results/">See workflow examples</a>
      </div>
    </div>
  </section>
</BaseLayout>
