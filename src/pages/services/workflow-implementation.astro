---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Workflow Implementation for UK SMEs"
  description="We identify repetitive work and build AI systems that save hours every week. From £3,500."
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Service</p>
      <h1>Workflow Implementation</h1>
      <p>We identify repetitive work and improve it using AI systems.</p>
      <a class="button" href="/contact/" data-cta="workflow-implementation-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Best for</p>
      <h2>Businesses losing hours to repetitive work</h2>
      <p class="lead">There's admin your team does every day or week that could be done faster. We find it, build the workflow, and hand it over.</p>
    </aside>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="section">
    <div class="section-header">
      <p class="eyebrow">What's included</p>
      <h2>End-to-end workflow design and implementation.</h2>
    </div>
    <div class="grid grid-3">
      <div>
        <h3>Workflow audit</h3>
        <p>We identify the tasks that repeat most often and cost the most time.</p>
      </div>
      <div>
        <h3>AI system design</h3>
        <p>We design the workflow using tools that fit your business.</p>
      </div>
      <div>
        <h3>Team handover</h3>
        <p>We train your team on how to use the new workflow.</p>
      </div>
      <div>
        <h3>Documentation</h3>
        <p>Step-by-step guides so your team can refer back.</p>
      </div>
      <div>
        <h3>Prompt library</h3>
        <p>Ready-to-use prompts for your specific workflows.</p>
      </div>
      <div>
        <h3>30-day follow-up</h3>
        <p>We check in to make sure everything is working smoothly.</p>
      </div>
    </div>
  </section>

  <!-- WHAT YOU LEAVE WITH -->
  <section class="section section-tight chapter">
    <div class="section-header">
      <p class="eyebrow">What you leave with</p>
      <h2>Built and tested workflows your team can use immediately.</h2>
    </div>
    <div class="grid grid-3">
      {[
        ["Working workflow", "Tested and ready for your team to use."],
        ["Team confidence", "Your team knows how to run the workflow."],
        ["Documentation", "Step-by-step guides for reference."],
        ["Prompt library", "Tailored to your specific workflows."],
      ].map(([title, body]) => (
        <article class="card card-featured">
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- USE CASES -->
  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Use cases</p>
      <h2>Workflows we commonly implement.</h2>
    </div>
    <div class="grid grid-3">
      {[
        ["Admin tasks", "Automate repetitive admin that wastes hours every week."],
        ["Reporting", "Turn notes and data into readable reports faster."],
        ["Internal knowledge search", "Make your documents searchable and useful."],
        ["Sales follow-up", "Prepare timely, personalized follow-ups from CRM notes."],
        ["Document workflows", "Streamline SOPs and internal processes."],
      ].map(([title, body]) => (
        <article class="card card-interactive">
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- PROBLEM IT SOLVES -->
  <section class="section section-tight">
    <div class="split">
      <div class="panel panel-pad">
        <p class="eyebrow">Problems it solves</p>
        <h2>Common workflow challenges we fix.</h2>
        <ul class="checklist">
          <li>Hours lost to repetitive admin</li>
          <li>No clear system for recurring tasks</li>
          <li>Team unsure how to use AI effectively</li>
          <li>Workflows that break down over time</li>
          <li>No documentation or handover process</li>
        </ul>
      </div>
      <div>
        <h3>Deliverables</h3>
        <ul class="checklist">
          <li>Workflow audit and mapping document</li>
          <li>Built and tested AI workflow</li>
          <li>Team training session</li>
          <li>Documentation and prompt library</li>
          <li>30-day follow-up support</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-tight">
    <div class="section-header">
      <h2>Frequently asked questions</h2>
    </div>
    <div class="grid grid-2">
      {[
        ["Do you sell software?", "No. We build workflows using tools you already use or recommend the right fit."],
        ["How long does implementation take?", "Typically 2-4 weeks from audit to handover, depending on complexity."],
        ["Will our data be safe?", "Yes. We follow strict data handling rules and never put sensitive data into public tools."],
        ["What if the workflow needs changes?", "We include 30 days of support to refine and adjust as needed."],
        ["Can you train our whole team?", "Yes. We include training for everyone who will use the workflow."],
      ].map(([q, a]) => (
        <details class="faq-item">
          <summary>{q}</summary>
          <p>{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- PRICING -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <p class="eyebrow">Pricing</p>
        <h2>From £3,500</h2>
      </div>
      <p>Price depends on workflow complexity and number of team members. Book a free discovery call to get an exact quote.</p>
      <div class="button-row" style="margin-top: 24px;">
        <a class="button" href="/contact/" data-cta="workflow-implementation-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
        <a class="button button-secondary" href="/pricing/">See all pricing</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <h2>Ready to automate your workflows?</h2>
        <p>Book a free discovery call and we'll identify where AI can save you the most time.</p>
      </div>
      <a class="button" href="/contact/" data-cta="workflow-implementation-cta-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
    </div>
  </section>
</BaseLayout>
