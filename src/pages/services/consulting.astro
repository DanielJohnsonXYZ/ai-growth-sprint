---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const included = [
  { icon: "🔍", title: "AI readiness assessment", body: "A thorough review of your current tools, systems, workflows, and team capabilities." },
  { icon: "🗺️", title: "Prioritised AI roadmap", body: "A clear, ranked list of AI opportunities ordered by impact and ease of implementation." },
  { icon: "🛠️", title: "Tool selection & guidance", body: "Honest, vendor-neutral advice on which tools to use — and which to avoid." },
  { icon: "📋", title: "Implementation planning", body: "Realistic timelines, milestones, and ownership for each initiative in the roadmap." },
  { icon: "💬", title: "Regular strategy sessions", body: "Monthly or bi-monthly working sessions to review progress and adapt the plan." },
  { icon: "📩", title: "Ongoing access between sessions", body: "Reach out whenever something comes up — I respond within 1 business day." },
];

const options = [
  {
    name: "Strategy Sprint",
    type: "Project-based",
    duration: "6–8 weeks",
    description: "A focused, fixed-scope engagement that delivers your AI roadmap and gets the first initiatives live. Ideal for businesses that want clear deliverables with a defined end date.",
    ideal: "Best for: founders who want a roadmap and a clear starting point",
  },
  {
    name: "Strategic Partner",
    type: "Monthly retainer",
    duration: "Ongoing",
    description: "Ongoing strategic support as your business evolves. Monthly sessions, implementation reviews, and open access for questions and decisions as they arise.",
    ideal: "Best for: leaders who want an ongoing AI advisor in their corner",
    featured: true,
  },
];
---

<Layout
  title="1:1 Strategy Consulting"
  description="Personalised AI strategy consulting for SMB founders and CEOs. Build a clear roadmap, choose the right tools, and implement AI that actually works."
>
  <Header />

  <main>
    <section class="pt-16 pb-14 bg-white border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl">
          <a href="/services" class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-brand-600 mb-6 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            All Services
          </a>
          <p class="text-brand-600 font-semibold text-sm uppercase tracking-wider mb-3">1:1 Strategy Consulting</p>
          <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-5">
            Your personal AI strategist
          </h1>
          <p class="text-gray-500 text-lg leading-relaxed mb-8">
            I work directly with you — the founder or leader — to build an AI strategy that fits your business, not a generic template. You'll get clarity, a prioritised plan, and a trusted partner who's invested in your results.
          </p>
          <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3.5 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors shadow-sm">
            Apply for a Strategy Session
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div class="reveal">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Who this is for</h2>
            <p class="text-gray-600 leading-relaxed mb-6">
              1:1 consulting is for business owners who want a strategic partner — someone to help them cut through the noise, make smart decisions, and build an AI strategy that actually fits their business.
            </p>
            <ul class="space-y-3">
              {[
                "Founders and CEOs who want clarity, not more information",
                "Leaders who've tried AI tools alone but aren't seeing real results",
                "Business owners who want to move fast but don't want to get it wrong",
                "Those who've been burned by expensive consultants that delivered little",
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <div class="mt-0.5 w-5 h-5 rounded-full flex-shrink-0 bg-brand-100 flex items-center justify-center">
                    <svg class="w-3 h-3 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                  <span class="text-gray-700 text-sm">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="reveal reveal-delay-2 bg-brand-700 rounded-2xl p-8 text-white">
            <p class="text-brand-300 text-xs font-semibold uppercase tracking-wider mb-4">Expected outcomes within 90 days</p>
            <ul class="space-y-4">
              {[
                { stat: "Clear roadmap", detail: "A prioritised list of AI opportunities you can act on immediately" },
                { stat: "Time savings", detail: "Measurable hours saved per week through better tooling and workflows" },
                { stat: "Smarter spend", detail: "Reduced tech costs by eliminating tools that don't deliver ROI" },
                { stat: "Competitive edge", detail: "Faster AI adoption than your peers in the same market" },
              ].map((o) => (
                <li class="border-b border-brand-600 pb-4 last:border-0 last:pb-0">
                  <p class="font-semibold text-white">{o.stat}</p>
                  <p class="text-brand-200 text-sm mt-0.5">{o.detail}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- What's included -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-12 reveal">
          <h2 class="text-2xl font-bold text-gray-900 mb-3">What's included</h2>
          <p class="text-gray-500">Every engagement is tailored. This is what you can consistently expect across all consulting work.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {included.map((item, i) => (
            <div class={`reveal reveal-delay-${(i % 3) + 1} bg-gray-50 rounded-xl p-6 border border-gray-100`}>
              <span class="text-2xl mb-3 block">{item.icon}</span>
              <h3 class="font-semibold text-gray-900 mb-2">{item.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Engagement options -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-12 reveal">
          <h2 class="text-2xl font-bold text-gray-900 mb-3">How we can work together</h2>
          <p class="text-gray-500">Two engagement models — choose what fits your situation and commitment level.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
          {options.map((o, i) => (
            <div class={`reveal reveal-delay-${i + 1} rounded-2xl p-8 ${o.featured ? 'bg-brand-700 ring-2 ring-brand-500' : 'bg-white border border-gray-200'} shadow-sm`}>
              {o.featured && <span class="inline-block px-3 py-1 bg-brand-500 text-white text-xs font-semibold rounded-full mb-4">Most popular</span>}
              <p class={`text-xs font-semibold uppercase tracking-wider mb-1 ${o.featured ? 'text-brand-300' : 'text-brand-600'}`}>{o.type}</p>
              <h3 class={`text-xl font-bold mb-1 ${o.featured ? 'text-white' : 'text-gray-900'}`}>{o.name}</h3>
              <p class={`text-sm font-medium mb-4 ${o.featured ? 'text-brand-200' : 'text-gray-400'}`}>{o.duration}</p>
              <p class={`text-sm leading-relaxed mb-4 ${o.featured ? 'text-brand-100' : 'text-gray-600'}`}>{o.description}</p>
              <p class={`text-sm italic ${o.featured ? 'text-brand-300' : 'text-gray-400'}`}>{o.ideal}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-white">
      <div class="max-w-2xl mx-auto px-4 text-center reveal">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Ready to build your AI strategy?</h2>
        <p class="text-gray-500 mb-7">I take on a small number of consulting clients at a time to ensure quality. Apply for a strategy session to see if we're a good fit.</p>
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3.5 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors shadow-sm">
          Apply for a Strategy Session
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
        <p class="text-gray-400 text-sm mt-4">No commitment required. I'll reply within 1 business day.</p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
