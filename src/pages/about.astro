---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const values = [
  { title: "Practical over theoretical", body: "I don't teach AI concepts in the abstract. Every session, every recommendation is grounded in what will actually work in your business next week." },
  { title: "Human-led, always", body: "AI is a tool, not a replacement. My work is about helping your team use it well — the judgment, the relationships, and the decisions stay with the humans." },
  { title: "No jargon, no hype", body: "I'm not here to impress you with buzzwords or oversell what AI can do. I tell you what's real, what's relevant, and what's worth your time." },
  { title: "SMBs first, always", body: "I work exclusively with small and mid-size businesses. Not enterprise. Not government. I know the constraints you operate under, and I build for them." },
];
---

<Layout
  title="About"
  description="Learn about Human Approved AI — who we are, why we focus on small businesses, and what makes our approach to AI adoption different."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="pt-16 pb-14 bg-white border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="reveal">
            <p class="text-brand-600 font-semibold text-sm uppercase tracking-wider mb-3">About</p>
            <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-6">
              AI expertise that actually fits your business
            </h1>
            <p class="text-gray-600 leading-relaxed text-lg">
              I'm an AI consultant who works exclusively with small and mid-size businesses. Not enterprise. Not government. Just real businesses, with real teams, who deserve access to the same competitive advantages as the big players — without the big-firm price tag or the one-size-fits-all programme.
            </p>
          </div>
          <div class="reveal reveal-delay-2 flex justify-center lg:justify-end">
            <div class="relative">
              <div class="w-64 h-64 rounded-3xl bg-brand-100 flex items-center justify-center">
                <svg class="w-32 h-32 text-brand-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                </svg>
              </div>
              <div class="absolute -bottom-4 -right-4 bg-brand-600 text-white rounded-2xl px-4 py-2 text-sm font-semibold shadow-lg">
                50+ businesses helped
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Story -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="reveal">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Why I focus on small businesses</h2>
          <div class="prose prose-gray max-w-none space-y-4 text-gray-600 leading-relaxed">
            <p>
              When the AI wave hit, I noticed something frustrating: most of the advice, training, and consulting was aimed at large enterprises with dedicated IT departments, data science teams, and six-figure technology budgets. The small business owner trying to figure out if AI could help their 12-person team? They were on their own.
            </p>
            <p>
              That gap is what Human Approved AI was built to close. I've spent years working at the intersection of technology and business strategy — and what I've learned is that the fundamentals don't change based on company size. The questions are the same. The opportunities are the same. What's different is the budget, the team size, and the need for solutions that actually fit the reality of a small business.
            </p>
            <p>
              My approach is deliberately different from the enterprise consulting model. There are no junior analysts, no 40-slide decks, no recommendations that assume you have six months and a dedicated project team to implement them. Everything I do is designed to be acted on — quickly, practically, and by real people with day jobs.
            </p>
            <p>
              I take on a limited number of clients at a time to ensure that every business I work with gets proper attention. If I can't commit to doing this well for you, I'll tell you honestly.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-12 reveal">
          <h2 class="text-2xl font-bold text-gray-900 mb-3">What I believe</h2>
          <p class="text-gray-500">The principles that shape how I work with every client.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {values.map((v, i) => (
            <div class={`reveal reveal-delay-${i + 1} bg-gray-50 rounded-2xl p-7 border border-gray-100`}>
              <h3 class="font-bold text-gray-900 mb-3">{v.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Credentials -->
    <section class="py-16 bg-brand-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center reveal">
          <h2 class="text-2xl font-bold text-white mb-10">By the numbers</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
            {[
              { stat: "50+", label: "businesses helped" },
              { stat: "12+", label: "industries covered" },
              { stat: "95%", label: "client retention" },
              { stat: "4.9★", label: "average rating" },
            ].map((item) => (
              <div class="text-center">
                <p class="text-4xl font-extrabold text-white mb-1">{item.stat}</p>
                <p class="text-brand-300 text-sm">{item.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-white">
      <div class="max-w-2xl mx-auto px-4 text-center reveal">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Let's work together</h2>
        <p class="text-gray-500 mb-7">Book a free 30-minute discovery call to talk through what you're trying to achieve and how I can help.</p>
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3.5 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors shadow-sm">
          Book a Free Discovery Call
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
