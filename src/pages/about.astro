---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@type": "Person",
  name: "Daniel Johnson",
  jobTitle: "Founder",
  worksFor: { "@type": "Organization", name: "Human Approved AI" },
};
---

<BaseLayout
  title="Human-First AI Adoption"
  description="Human Approved AI was built for businesses who know AI matters but are tired of hype, jargon, and bad advice."
  schema={schema}
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">About</p>
      <h1>Human-First AI Adoption</h1>
      <p>
        Human Approved AI was built for businesses who know AI matters, but are
        tired of hype, jargon, and bad advice.
      </p>
      <a class="button" href="/contact/" data-cta="about-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Our approach</p>
      <h2>Commercial thinking. Practical implementation. Plain-English communication.</h2>
      <p class="lead">We help established businesses modernise intelligently — without the chaos.</p>
    </aside>
  </section>

  <!-- FOUNDER SECTION -->
  <section class="section">
    <div class="split">
      <div>
        <img src="/founder-photo.jpg" alt="Daniel Johnson, Founder" style="width:100%; max-width:400px; border:2px solid var(--ink); border-radius: var(--radius);" />
      </div>
      <div>
        <p class="eyebrow">Who you work with</p>
        <h2>Direct access to experienced guidance.</h2>
        <p><strong>Daniel Johnson, Founder</strong></p>
        <p>Helping UK SMEs adopt AI without the hype since 2023. Practical, commercial-first, and always focused on real business outcomes.</p>
      </div>
    </div>
  </section>

  <!-- FOUNDER SECTION -->
  <section class="section chapter">
    <div class="section-header">
      <p class="eyebrow">Who we are</p>
      <h2>We combine commercial thinking, practical implementation, and plain-English communication.</h2>
      <p>
        Human Approved AI works with established UK businesses to help them
        adopt AI in ways that create real value. Not tool demos. Not generic
        workshops. Practical work built around your business.
      </p>
    </div>
    <div class="grid grid-3">
      {([
        ["Commercial-first", "We focus on where AI creates ROI, not where it looks impressive."],
        ["Plain-English", "No jargon. No buzzwords. Just clear advice on what to do and why."],
        ["Practical delivery", "We train people on real work, not invented examples."],
      ] as const).map(([title, body]) => (
        <article class="card">
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- CREDIBILITY / LOGO POLICY -->
  <section class="section section-tight" aria-label="Credibility and logos">
    <div class="panel panel-pad card-quiet">
      <p class="eyebrow">Credibility</p>
      <h2>Focused proof for SME AI adoption</h2>
      <p>
        We only use <strong>client stories, logos, or named proof</strong> on this site when it directly supports
        AI training and workflow adoption for UK SMEs <strong>and</strong> we have permission. Broader speaking,
        podcast, or other brand assets stay on Daniel’s other sites so Human Approved AI stays clear for cautious buyers.
      </p>
    </div>
  </section>

  <!-- FOUNDER STORY -->
  <section class="section section-tight chapter">
    <div class="section-header">
      <p class="eyebrow">Our story</p>
      <h2>Why Human Approved AI exists</h2>
    </div>
    <div class="split">
      <div>
        <p>Most businesses know AI matters but feel overwhelmed by hype, jargon, and conflicting advice. They don't need "AI transformation." They need someone to look at their actual work and show them where AI saves time.</p>
        <p>We started Human Approved AI to give UK SMEs practical, human-first AI adoption — starting with workflows, not tools.</p>
      </div>
      <div>
        <h3>Our principles</h3>
        <ul class="checklist">
          <li><strong>Start with the work</strong> — we look at what your team actually does</li>
          <li><strong>Keep humans responsible</strong> — AI drafts, people decide</li>
          <li><strong>Prioritise time saved</strong> — measurable outcomes, not vanity metrics</li>
          <li><strong>Train on real tasks</strong> — your work, not invented examples</li>
          <li><strong>Avoid unnecessary software</strong> — use what works, not what's trending</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- WHY WE EXIST -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <p class="eyebrow">Why we exist</p>
        <h2>Many businesses don't need "AI transformation".</h2>
        <p>They need:</p>
      </div>
      <ul class="checklist">
        <li>Clear advice</li>
        <li>Better systems</li>
        <li>Trained teams</li>
        <li>Trusted support</li>
        <li>Commercial results</li>
      </ul>
      <p style="margin-top: 20px; font-weight: 700; color: var(--ink)">That's what we deliver.</p>
    </div>
  </section>

  <!-- WHAT WE DON'T DO -->
  <section class="section section-tight chapter">
    <div class="split">
      <div class="section-header">
        <p class="eyebrow">What we're not</p>
        <h2>Not a software vendor. Not a generic trainer.</h2>
        <p>
          We're not here to sell you a tool or run a one-size-fits-all
          workshop. We look at your actual business, find where AI saves time
          or creates value, and help you act on it.
        </p>
      </div>
      <div class="grid">
        {([
          ["Not software-led", "We work with the tools you already use or recommend the right fit — not sell a subscription."],
          ["Not theoretical", "Everything is built around real tasks from your business, not invented examples."],
          ["Not a one-off", "We offer ongoing support because AI keeps changing and your business needs to keep pace."],
        ] as const).map(([title, body]) => (
          <article class="card">
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <h2>Ready to talk?</h2>
        <p>Book a free discovery call and we'll figure out where AI can make a real difference in your business.</p>
      </div>
      <div class="button-row">
        <a class="button" href="/contact/" data-cta="about-cta-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
        <a class="button button-secondary" href="/services/" data-cta="about-services">See services</a>
      </div>
    </div>
  </section>
</BaseLayout>
