---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@type": "Person",
  name: "Daniel Johnson",
  jobTitle: "Founder",
  worksFor: { "@type": "Organization", name: "Human Approved AI" },
};
---

<BaseLayout
  title="About"
  description="About Daniel Johnson and the thinking behind Human Approved AI."
  schema={schema}
>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">About</p>
      <h1>Built by someone who's worked with teams, not just talked about AI.</h1>
      <p>
        Human Approved AI came from a simple observation: most teams try AI a
        couple of times, don't get much out of it, and go back to doing things
        the old way. The problem isn't the tools. It's that nobody showed them
        how to use it on the work they actually do.
      </p>
      <a class="button" href="/contact/">Book a free call</a>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Background</p>
      <h2>Google for Startups, Techstars, Cambridge, Imperial, UK Space Agency.</h2>
      <p class="lead">Daniel has trained and mentored teams across programmes backed by these organisations.</p>
    </aside>
  </section>

  <section class="section">
    <div class="grid grid-3">
      <article class="card"><h3>10+ years in growth</h3><p>Hands-on growth marketing and startup support, not theory from a textbook.</p></article>
      <article class="card"><h3>Two startup exits</h3><p>Built and sold businesses, so understands what it's like when time is the constraint.</p></article>
      <article class="card"><h3>Practical over clever</h3><p>The training is designed to work on Monday morning, not just sound good on the day.</p></article>
    </div>
  </section>

  <section class="section section-tight">
    <div class="panel panel-pad">
      <p class="eyebrow">See the work</p>
      <h2>What teams actually build in a session.</h2>
      <p class="lead">Workflow examples from real teams, with time savings and before-and-after comparisons.</p>
      <div class="button-row" style="margin-top: 24px">
        <a class="button" href="/results/">See results</a>
        <a class="button button-secondary" href="/how-it-works/">How it works</a>
      </div>
    </div>
  </section>
</BaseLayout>
