---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="How It Works"
  description="How AI Growth Sprint makes AI adoption safe, practical, and permanent for SME teams."
>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">How it works</p>
      <h1>One day to build AI habits your team can trust tomorrow.</h1>
      <p>
        The workshop is built around your actual work: the documents, emails,
        reports, proposals, and admin tasks your team already handles every week,
        with clear rules for data, quality, tone, and sign-off.
      </p>
      <a class="button" href="/contact/">Book a free 15-minute call</a>
    </div>
    <aside class="panel panel-pad">
      <h2>Not a lecture.</h2>
      <p class="lead">Your team practices on real tasks, leaves with reusable rules and templates, and gets 30-day follow-up support.</p>
    </aside>
  </section>

  <section class="section">
    <div class="grid grid-4">
      {[
        ["1", "Quick call", "You tell us where AI feels risky or messy. We identify the safest useful workflows first."],
        ["2", "Custom build", "We design the session around your industry, tools, approval rules, and actual work."],
        ["3", "Workshop day", "Your team uses AI on real tasks and leaves with 5+ repeatable prepare-and-approve workflows."],
        ["4", "30-day check-in", "We answer questions, troubleshoot, and make sure the new way of working sticks."],
      ].map(([step, title, body]) => (
        <article class="card">
          <p class="eyebrow">Step {step}</p>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight chapter">
    <div class="split">
      <div class="section-header">
        <p class="eyebrow">What your team leaves with</p>
        <h2>Useful assets, not a slide deck nobody opens again.</h2>
      </div>
      <div class="grid">
        {["A workbook with every workflow written out step by step", "Prompt, approval, and data-safety templates", "Before/after workflow examples for your team", "A post-workshop adoption checklist", "30 days of email support"].map((item) => (
          <article class="card card-interactive">
            <strong>{item}</strong>
            <p>Built to be reused after the session, not just discussed during it.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="panel panel-pad">
      <p class="eyebrow">Trust note</p>
      <h2>We teach approval boundaries from the start.</h2>
      <p class="lead">
        The rule is simple: AI prepares, people approve. We cover what not to
        paste into public tools, how to check outputs, and where AI should never
        be treated as final authority.
      </p>
      <div class="button-row" style="margin-top: 24px">
        <a class="button" href="/trust-security/">Read trust and security</a>
        <a class="button button-secondary" href="/pricing/">Compare packages</a>
      </div>
    </div>
  </section>
</BaseLayout>
