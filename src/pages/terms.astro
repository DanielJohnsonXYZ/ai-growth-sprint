---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../data/site";
---

<BaseLayout
  title="Terms of use"
  description="Terms for using the Human Approved AI website. Informational content only — not legal advice."
>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Legal</p>
      <h1>Terms of use</h1>
      <p>
        These terms explain how you may use this website. They are written in
        plain English for UK visitors. They are not a substitute for legal
        advice.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="panel panel-pad prose">
      <h2>Using this site</h2>
      <p>
        You may browse <strong>{SITE.name}</strong> ({SITE.url}) for lawful
        purposes. Do not attempt to disrupt the site, scrape it at scale without
        permission, or misuse any forms or contact details published here.
      </p>

      <h2>Information, not advice</h2>
      <p>
        Content on this site describes how we work and how teams can think about
        AI adoption. It is general information. It is{" "}
        <strong>not</strong> legal, financial, technical, or professional advice
        for your situation. You are responsible for your own decisions and for
        complying with laws and regulations that apply to you.
      </p>

      <h2>Services</h2>
      <p>
        Nothing on this site promises a specific outcome, timeline, or price
        unless we confirm it in writing as part of an engagement. A discovery
        call does not create a contract.
      </p>

      <h2>Links</h2>
      <p>
        We may link to third-party sites for convenience. We do not control
        those sites and are not responsible for their content or practices.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about these terms:{" "}
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .prose h2 {
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .prose p {
    margin: 0 0 1rem;
    color: var(--muted);
  }

  .prose a {
    color: var(--moss);
    font-weight: 700;
  }
</style>
