---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="AI Solutions by Industry"
  description="Tailored AI adoption for accountants, recruiters, legal, property, manufacturing, and agencies. Practical support for how your business actually operates."
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Industries</p>
      <h1>AI Solutions by Industry</h1>
      <p>
        Every sector has different workflows, pressures, and opportunities. We
        tailor AI adoption to how your business actually operates.
      </p>
      <a class="button" href="/contact/" data-cta="industries-hero-book">Book Free Discovery Call</a>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Tailored, not generic</p>
      <h2>We start from your workflows, not a template.</h2>
      <p class="lead">The same AI principles apply everywhere. The implementation is always specific to how your business actually runs.</p>
    </aside>
  </section>

  <!-- INDUSTRY CARDS -->
  <section class="section">
    <div class="grid grid-3">
      {([
        ["Accountants", "Reduce admin, improve client comms, streamline documents.", "/industries/accounting/"],
        ["Recruitment", "Candidate outreach, job ad creation, CRM workflows.", "/industries/recruitment/"],
        ["Legal", "Drafting support, admin efficiency, internal knowledge tools.", "/industries/legal/"],
        ["Property", "Enquiries, listings, marketing, operations.", "/industries/property/"],
        ["Manufacturing", "Reporting, SOPs, admin processes.", "/industries/manufacturing/"],
        ["Agencies", "Delivery systems, sales workflows, content operations.", "/contact/"],
      ] as const).map(([title, body, href]) => (
        <article class="card highlight card-interactive">
          <p class="eyebrow">{title}</p>
          <h3>{title}</h3>
          <p>{body}</p>
          <a href={href} data-cta={`industry-${title.toLowerCase()}`}>See {title.toLowerCase()} examples</a>
        </article>
      ))}
    </div>
  </section>

  <!-- HOW WE TAILOR IT -->
  <section class="section section-tight chapter">
    <div class="section-header">
      <p class="eyebrow">How we work</p>
      <h2>We map your sector's specific workflows before recommending anything.</h2>
      <p>
        Every industry has its own admin patterns, compliance pressures, and
        bottlenecks. We start by understanding yours — then we build AI
        adoption around the work your team actually does.
      </p>
    </div>
    <div class="grid grid-3">
      {([
        ["Workflow mapping", "We identify the tasks that repeat most often and cost the most time."],
        ["Sector-specific tooling", "We recommend tools that fit your industry's compliance and data needs."],
        ["Team training", "We train your team on real examples from your sector, not invented ones."],
      ] as const).map(([title, body]) => (
        <article class="card">
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <h2>Don't see your industry?</h2>
        <p>We work across a wide range of sectors. Book a call and we'll tell you exactly how AI applies to your business.</p>
      </div>
      <a class="button" href="/contact/" data-cta="industries-cta-book">Book Free Discovery Call</a>
    </div>
  </section>
</BaseLayout>
