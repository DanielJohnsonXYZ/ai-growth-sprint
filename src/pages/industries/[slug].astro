---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getUseCase, industries, packages, SITE } from "../../data/site";

export function getStaticPaths() {
  return industries.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;
const relatedUseCases = industry.relatedUseCases.map((slug: string) => getUseCase(slug)).filter(Boolean);
const relatedUseCaseCards = relatedUseCases.map((useCase) => ({
  useCase,
  example: useCase?.examples.find((example) =>
    example.industry === industry.shortName ||
    example.industry === industry.title ||
    industry.title.includes(example.industry) ||
    example.industry.includes(industry.shortName)
  ),
}));
const isAccounting = industry.slug === "accounting";
const sectorPainTitle = isAccounting
  ? "Every tax deadline creates the same quality-control drag."
  : `Why ${industry.shortName.toLowerCase()} teams feel the pain.`;
const midCtaLabel = isAccounting ? "See which workflow fits your firm" : "Book a free 15-minute call";
const primaryPackage = packages[0];
const schema = {
  "@type": "Service",
  name: `AI training for ${industry.title}`,
  provider: { "@type": "Organization", name: SITE.name, url: SITE.url },
  areaServed: "United Kingdom",
  serviceType: "AI workflow training",
};
---

<BaseLayout title={industry.metaTitle} description={industry.metaDescription} schema={schema}>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">AI training for {industry.shortName.toLowerCase()}</p>
      <h1>{industry.hero}</h1>
      <p>{industry.subhero}</p>
      <div class="hero-actions">
        <a class="button" href="/contact/">Book a free 15-minute call</a>
        <a class="button button-secondary" href="/how-it-works/">How it works</a>
      </div>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Why {industry.shortName.toLowerCase()}</p>
      <h2>{sectorPainTitle}</h2>
      <p class="lead">{industry.stat}</p>
    </aside>
  </section>

  <section class="section section-tight">
    <div class="grid grid-4">
      <article class="card card-featured">
        <p class="eyebrow">{isAccounting ? "Firm fit" : "Who it is for"}</p>
        <h3>{industry.audience}</h3>
        <p>{industry.size}</p>
      </article>
      <article class="card">
        <p class="eyebrow">Results</p>
        <h3>Case studies added as completed</h3>
        <p>{industry.proofNote}</p>
      </article>
      <article class="card">
        <p class="eyebrow">Pricing signal</p>
        <h3>{primaryPackage.price}</h3>
        <p>Best fit for a private workshop with a team working through real workflows.</p>
      </article>
      <article class="card">
        <p class="eyebrow">Next step</p>
        <h3>{midCtaLabel}</h3>
        <p>Tell us where AI feels useful but risky. We will map the first workflows worth adopting safely.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">5 workflows</p>
      <h2>Where AI can make the work safer and faster.</h2>
      <p>
        Each workflow is designed as a prepare-and-approve process. AI helps
        create the working version. The team stays responsible for facts,
        judgment, tone, and sign-off.
      </p>
    </div>
    <div class="workflow">
      {industry.workflows.map((workflow) => (
        <article class="workflow-row">
          <div>
            <p class="eyebrow">Task</p>
            <strong>{workflow.name}</strong>
          </div>
          <div>
            <p class="eyebrow">Before</p>
            <p>{workflow.now}</p>
          </div>
          <div>
            <p class="eyebrow">After</p>
            <p>{workflow.withAi}</p>
          </div>
          <div>
            <p class="eyebrow">Time saved</p>
            <p>{workflow.timeSaved}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight">
    <div class="split">
      <div class="panel panel-pad">
        <p class="eyebrow">Trust block</p>
        <h2>Safe use for {industry.shortName}.</h2>
        <p class="lead">{industry.trustNote}</p>
        <a class="button" style="margin-top: 24px" href="/trust-security/">Read trust and security</a>
      </div>
      <div>
        <div class="section-header">
          <p class="eyebrow">Sector insights</p>
          <h2>What makes {industry.shortName.toLowerCase()} different.</h2>
        </div>
        <div class="grid">
          {industry.insights.map((insight) => (
            <article class="card">
              <strong>{insight}</strong>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Related use cases</p>
      <h2>{isAccounting ? "Accounting examples, not generic use cases." : "Same workflows, connected across sectors."}</h2>
    </div>
    <div class="grid grid-3">
      {relatedUseCaseCards.map(({ useCase, example }) => (
        <article class="card card-interactive">
          <p class="eyebrow">{useCase?.title}</p>
          <h3>{example ? example.current : useCase?.hero}</h3>
          <p>{example ? `${example.ai} ${example.review}` : useCase?.problem}</p>
          <a href={`/use-cases/${useCase?.slug}/`}>View use case</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight">
    <div class="panel panel-pad">
      <p class="eyebrow">Next step</p>
      <h2>Want to see where AI could help {industry.shortName.toLowerCase()} without creating a mess?</h2>
      <p class="lead">Book a short call. Bring the tasks your team wants to improve and the risks you want controlled.</p>
      <a class="button" style="margin-top: 24px" href="/contact/">Book a free 15-minute call</a>
    </div>
  </section>
</BaseLayout>
