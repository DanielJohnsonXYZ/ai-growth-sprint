---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getUseCase, industries, packages, SITE } from "../../data/site";

export function getStaticPaths() {
  return industries.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;
const relatedUseCases = industry.relatedUseCases.map((slug: string) => getUseCase(slug)).filter(Boolean);
const relatedUseCaseCards = relatedUseCases.map((useCase) => ({
  useCase,
  example: useCase?.examples.find((example) =>
    example.industry === industry.shortName ||
    example.industry === industry.title ||
    industry.title.includes(example.industry) ||
    example.industry.includes(industry.shortName)
  ),
}));
const primaryPackage = packages[0];
const leadMagnets: Record<string, string> = {
  construction: "10 Ways Construction Firms Can Use AI to Win More Tenders",
  accounting: "How Accountancy Firms Use AI to Save 10+ Hours Per Week",
  property: "AI for Estate Agents: Faster Listings, Faster Follow-Up"
};
const leadMagnet = leadMagnets[industry.slug] ?? `Where AI Can Make or Save Money in a ${industry.shortName} Team`;
const guideSlugByIndustry: Record<string, string> = {
  construction: "construction-ai-tenders",
  accounting: "accountancy-ai-admin",
  property: "estate-agent-ai-follow-up"
};
const guideHref = `/guides/${guideSlugByIndustry[industry.slug] ?? "uk-sme-ai-opportunities"}/`;
const serviceSchema = {
  "@type": "Service",
  name: `AI training for ${industry.title}`,
  provider: { "@type": "Organization", name: SITE.name, url: SITE.url },
  areaServed: "United Kingdom",
  serviceType: "AI workflow training",
};
const faqSchema =
  industry.faqs && industry.faqs.length > 0
    ? {
        "@type": "FAQPage",
        mainEntity: industry.faqs.map(({ q, a }) => ({
          "@type": "Question",
          name: q,
          acceptedAnswer: { "@type": "Answer", text: a },
        })),
      }
    : null;
const schema = faqSchema ? [serviceSchema, faqSchema] : serviceSchema;
---

<BaseLayout title={industry.metaTitle} description={industry.metaDescription} schema={schema}>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">AI training for {industry.shortName.toLowerCase()}</p>
      <h1>{industry.hero}</h1>
      <p>{industry.subhero}</p>
      <div class="hero-actions">
        <a class="button" href="/contact/" data-cta="industry-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
        <a class="button button-secondary" href="/how-it-works/" data-cta="industry-how">See How It Works</a>
      </div>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Why {industry.shortName.toLowerCase()}</p>
      <h2>Where the time goes.</h2>
      <p class="lead">{industry.stat}</p>
    </aside>
  </section>

  <section class="section section-tight">
    <div class="grid grid-4">
      <article class="card card-featured">
        <p class="eyebrow">Who this is for</p>
        <h3>{industry.audience}</h3>
        <p>{industry.size}</p>
      </article>
      <article class="card">
        <p class="eyebrow">Results</p>
        <h3>Case studies being collected</h3>
        <p>Named examples added as they're confirmed. Nothing made up.</p>
      </article>
      <article class="card">
        <p class="eyebrow">Starting from</p>
        <h3>{primaryPackage.price}</h3>
        <p>For a private workshop built around your team's actual work.</p>
      </article>
      <article class="card">
        <p class="eyebrow">Next step</p>
        <h3>Book a quick call</h3>
        <p>Tell us where the time goes. We'll figure out which tasks are worth tackling first.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">5 workflows</p>
      <h2>Where AI actually saves time.</h2>
      <p>
        Each workflow follows the same pattern: AI helps put together a first
        pass, and your team checks it before anything goes out.
      </p>
    </div>
    <div class="workflow">
      {industry.workflows.map((workflow) => (
        <article class="workflow-row">
          <div>
            <p class="eyebrow">Task</p>
            <strong>{workflow.name}</strong>
          </div>
          <div>
            <p class="eyebrow">Before</p>
            <p>{workflow.now}</p>
          </div>
          <div>
            <p class="eyebrow">After</p>
            <p>{workflow.withAi}</p>
          </div>
          <div>
            <p class="eyebrow">Time saved</p>
            <p>{workflow.timeSaved}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight">
    <div class="panel panel-pad lead-magnet-panel">
      <p class="eyebrow">Free guide</p>
      <h2>{leadMagnet}</h2>
      <p class="lead">Useful if you want a quick, plain-English view of the best AI opportunities before booking training.</p>
      <div class="button-row" style="margin-top: 24px">
        <a class="button" href={guideHref}>Read the guide</a>
        <a class="button button-secondary" href={`/contact/?guide=${industry.slug}`}>Ask about training</a>
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="split">
      <div class="panel panel-pad">
        <p class="eyebrow">Keeping things under control</p>
        <h2>How this works safely for {industry.shortName.toLowerCase()}.</h2>
        <p class="lead">{industry.trustNote}</p>
        <a class="button" style="margin-top: 24px" href="/trust-security/">Trust and security</a>
      </div>
      <div>
        <div class="section-header">
          <p class="eyebrow">Why this industry</p>
          <h2>What makes {industry.shortName.toLowerCase()} different.</h2>
        </div>
        <div class="grid">
          {industry.insights.map((insight) => (
            <article class="card">
              <strong>{insight}</strong>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  {industry.faqs && industry.faqs.length > 0 && (
    <section class="section section-tight" aria-label={`${industry.shortName} FAQs`}>
      <div class="section-header">
        <p class="eyebrow">Common questions</p>
        <h2>FAQ for {industry.shortName.toLowerCase()} teams.</h2>
      </div>
      <div class="grid grid-2">
        {industry.faqs.map(({ q, a }) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <p>{a}</p>
          </details>
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Related workflows</p>
      <h2>These tasks come up across most {industry.shortName.toLowerCase()} teams.</h2>
    </div>
    <div class="grid grid-3">
      {relatedUseCaseCards.map(({ useCase, example }) => (
        <article class="card card-interactive">
          <p class="eyebrow">{useCase?.title}</p>
          <h3>{example ? example.current : useCase?.hero}</h3>
          <p>{example ? `${example.ai} ${example.review}` : useCase?.problem}</p>
          <a href={`/use-cases/${useCase?.slug}/`}>See examples</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight">
    <div class="panel panel-pad">
      <p class="eyebrow">Next step</p>
      <h2>Want to see where AI could help your {industry.shortName.toLowerCase()} team?</h2>
      <p class="lead">Book a short call. Tell us where the time goes and we'll figure out which tasks to start with.</p>
      <a class="button" href="/contact/" data-cta="industry-final-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
    </div>
  </section>
</BaseLayout>
