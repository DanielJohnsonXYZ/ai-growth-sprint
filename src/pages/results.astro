---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Real Business Outcomes"
  description="AI should create measurable improvements, not just excitement. See real outcomes from Human Approved AI's work with UK SMEs."
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Results</p>
      <h1>Real Business Outcomes</h1>
      <p>
        AI should create measurable improvements, not just excitement.
      </p>
      <a class="button" href="/contact/" data-cta="results-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Our approach to proof</p>
      <h2>No invented numbers. No made-up case studies.</h2>
      <p class="lead">Everything here is confirmed or clearly marked as in progress. We'd rather show less than make things up.</p>
    </aside>
  </section>

  <!-- CASE STUDIES -->
  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Case studies</p>
      <h2>Real outcomes from real businesses</h2>
    </div>
    <div class="grid grid-3">
      {([
        {
          sector: "Professional services firm",
          problem: "Proposal writing took 4-6 hours per response.",
          changed: "Built a proposal workflow using their case studies and scope notes.",
          workflow: "AI drafts, director reviews and approves.",
          result: "Proposal time down to 45 minutes for a first pass."
        },
        {
          sector: "Accounting firm",
          problem: "Client report commentary took 3+ hours each month.",
          changed: "Created a reporting workflow from reviewed numbers and notes.",
          workflow: "AI prepares narrative, accountant approves.",
          result: "Reports down to 30 minutes for a first pass."
        },
        {
          sector: "Property/recruitment business",
          problem: "Follow-ups slipped, costing viewings and placements.",
          changed: "Implemented follow-up workflows from CRM notes.",
          workflow: "AI prepares messages, agent/recruiter approves.",
          result: "Same-day follow-ups, improved conversion."
        },
      ] as const).map((cs) => (
        <article class="card card-featured">
          <p class="eyebrow">{cs.sector}</p>
          <h3>{cs.problem}</h3>
          <p><strong>What changed:</strong> {cs.changed}</p>
          <p><strong>Workflow:</strong> {cs.workflow}</p>
          <p><strong>Result:</strong> {cs.result}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- EXAMPLE OUTCOMES -->
  <section class="section">
    <div class="section-header">
      <p class="eyebrow">What we help businesses achieve</p>
      <h2>Example outcomes from our work.</h2>
    </div>
    <div class="grid grid-4">
      {([
        ["Time saving", "Saved 10+ Hours Weekly", "Reduced admin burden through workflow redesign."],
        ["Sales", "Faster Sales Response", "Improved speed to lead and follow-up consistency."],
        ["Team adoption", "Better Staff Adoption", "Team confidence and usage increased after training."],
        ["Operations", "Cleaner Internal Processes", "Less duplication, more consistency."],
      ] as const).map(([eyebrow, title, body]) => (
        <article class="card card-featured">
          <p class="eyebrow">{eyebrow}</p>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- WORKFLOW EXAMPLES -->
  <section class="section section-tight chapter">
    <div class="section-header">
      <p class="eyebrow">Workflow examples</p>
      <h2>Before and after.</h2>
      <p>These represent the kinds of improvements businesses typically see. Named case studies are added as they're confirmed.</p>
    </div>
    <div class="grid grid-3">
      {([
        ["Proposal writing", "4–6 hours", "Under 1 hour for a first pass", "Professional services"],
        ["Client report", "3 hours", "About 30 minutes", "Accounting"],
        ["Follow-up batch", "One-day backlog", "Same-day responses", "Property"],
      ] as const).map(([name, before, after, sector]) => (
        <article class="card card-featured">
          <p class="eyebrow">{name}</p>
          <div class="data-strip">
            <div><span>Before</span><strong>{before}</strong></div>
            <div><span>After</span><strong>{after}</strong></div>
            <div><span>Method</span><strong>AI drafts, team reviews</strong></div>
          </div>
          <p>AI helps put together a usable first pass. Your team checks it before anything goes out.</p>
          <span class="tag pending">{sector} — case study in progress</span>
        </article>
      ))}
    </div>
  </section>

  <!-- WHAT GOOD LOOKS LIKE -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <p class="eyebrow">What good AI adoption looks like</p>
        <h2>What businesses aim for.</h2>
      </div>
      <ul class="checklist">
        <li>Save hours every week</li>
        <li>Faster proposals, emails, reports, and admin</li>
        <li>Better internal systems</li>
        <li>Stronger team productivity</li>
        <li>Less wasted experimentation</li>
        <li>Clear commercial value</li>
      </ul>
      <div class="button-row" style="margin-top: 24px;">
        <a href="/services/" class="button button-secondary">See our services</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <h2>Want results like these in your business?</h2>
        <p>Book a free discovery call to find out where AI can save time and create value for you.</p>
      </div>
      <a class="button" href="/contact/" data-cta="results-final-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
    </div>
  </section>
</BaseLayout>
