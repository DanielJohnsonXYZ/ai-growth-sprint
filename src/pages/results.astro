---
import BaseLayout from "../layouts/BaseLayout.astro";
import { priorityIndustries, useCases } from "../data/site";
---

<BaseLayout
  title="Results"
  description="Workflow examples and time savings from real teams. Named case studies added as they're confirmed."
>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Results</p>
      <h1>What this looks like in practice.</h1>
      <p>
        These are the kinds of time savings teams see when they start using AI
        on the work they already do. Named case studies are being added as
        they're confirmed — nothing made up.
      </p>
      <a class="button" href="/contact/">Book a free call</a>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">How we handle proof</p>
      <h2>No invented quotes. No made-up numbers.</h2>
      <p class="lead">Everything here is either confirmed or clearly marked as in progress. We'd rather show less than make things up.</p>
    </aside>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Workflow examples</p>
      <h2>Before and after.</h2>
    </div>
    <div class="grid grid-3">
      {[
        ["Tender response", "6-8 hours", "About 90 minutes", "Construction"],
        ["Client report", "3 hours", "About 30 minutes", "Accounting"],
        ["Follow-up batch", "One-day backlog", "Same-day responses", "Property"],
      ].map(([name, before, after, sector]) => (
        <article class="card card-featured">
          <p class="eyebrow">{name}</p>
          <div class="data-strip">
            <div><span>Before</span><strong>{before}</strong></div>
            <div><span>After</span><strong>{after}</strong></div>
            <div><span>Method</span><strong>AI drafts, team reviews</strong></div>
          </div>
          <p>AI helps put together a usable first pass. Your team checks it before anything goes out.</p>
          <span class="tag pending">{sector} — case study in progress</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight chapter">
    <div class="section-header">
      <p class="eyebrow">ROI scenarios</p>
      <h2>Where the business case usually comes from.</h2>
      <p>These are planning examples, not guaranteed outcomes. The real numbers depend on your workflow, team size, and approval rules.</p>
    </div>
    <div class="grid grid-3">
      {[
        ["Five-person admin team", "Save 30 minutes per person per day on repeat writing and reporting tasks.", "Roughly 12.5 hours a week back."],
        ["Construction estimator", "Reduce tender first-pass prep from most of a day to a structured review draft.", "More time for pricing quality and proof."],
        ["Property branch", "Turn viewing notes into same-day follow-ups instead of a backlog.", "Faster response without losing local judgement."],
      ].map(([title, assumption, value]) => (
        <article class="card">
          <h3>{title}</h3>
          <p>{assumption}</p>
          <strong>{value}</strong>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight">
    <div class="section-header">
      <p class="eyebrow">Where we're collecting results first</p>
      <h2>Starting with the industries we know best.</h2>
    </div>
    <div class="grid grid-3">
      {priorityIndustries.map((industry) => (
        <article class="card">
          <h3>{industry.shortName}</h3>
          <p>Workflow examples and results from {industry.shortName.toLowerCase()} teams we've worked with.</p>
          <a href={`/industries/${industry.slug}/`}>See {industry.shortName.toLowerCase()} examples</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">By workflow type</p>
      <h2>The same tasks come up across different industries.</h2>
    </div>
    <div class="grid grid-3">
      {useCases.map((useCase) => (
        <article class="card">
          <h3>{useCase.title}</h3>
          <p>{useCase.problem}</p>
          <a href={`/use-cases/${useCase.slug}/`}>See examples</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
