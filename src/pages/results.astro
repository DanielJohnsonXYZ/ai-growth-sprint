---
import BaseLayout from "../layouts/BaseLayout.astro";
import { priorityIndustries, useCases } from "../data/site";
---

<BaseLayout
  title="Results and Proof"
  description="Proof system, workflow outcomes, and pending source material for AI Growth Sprint."
>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Results</p>
      <h1>Results from real teams, clearly labelled.</h1>
      <p>
        We only publish proof that has been approved. Workflow examples are
        shown below, and named testimonials and case studies will be added as
        they are confirmed.
      </p>
      <a class="button" href="/contact/">Book a free 15-minute call</a>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Our commitment</p>
      <h2>No invented quotes. No invented logos. No invented metrics.</h2>
      <p class="lead">Everything on this page is either approved proof or clearly marked as pending.</p>
    </aside>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Workflow examples</p>
      <h2>Before and after snapshots.</h2>
    </div>
    <div class="grid grid-3">
      {[
        ["Tender draft", "6-8 hours", "About 90 minutes", "Construction proof pending"],
        ["Client report", "3 hours", "About 30 minutes", "Accounting proof pending"],
        ["Follow-up batch", "One-day backlog", "Same-day drafts", "Property proof pending"],
      ].map(([name, before, after, proof]) => (
        <article class="card card-featured">
          <p class="eyebrow">{name}</p>
          <div class="data-strip">
            <div><span>Before</span><strong>{before}</strong></div>
            <div><span>After</span><strong>{after}</strong></div>
            <div><span>Method</span><strong>Draft then review</strong></div>
          </div>
          <p>AI helps create the draft. A human reviews before anything is sent.</p>
          <span class="tag pending">{proof}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight">
    <div class="section-header">
      <p class="eyebrow">Priority sectors</p>
      <h2>Where we are collecting proof first.</h2>
    </div>
    <div class="grid grid-3">
      {priorityIndustries.map((industry) => (
        <article class="card">
          <h3>{industry.shortName}</h3>
          <p>{industry.proofNote}</p>
          <a href={`/industries/${industry.slug}/`}>View industry page</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Explore by workflow</p>
      <h2>See how these tasks work across industries.</h2>
    </div>
    <div class="grid grid-3">
      {useCases.map((useCase) => (
        <article class="card">
          <h3>{useCase.title}</h3>
          <p>{useCase.problem}</p>
          <a href={`/use-cases/${useCase.slug}/`}>View workflow</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
