---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Book a Free Discovery Call"
  description="Book a free 30-minute discovery call with Human Approved AI. No obligation, no hard sell — just a conversation about what's possible for your business."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="pt-16 pb-14 bg-white border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl">
          <p class="text-brand-600 font-semibold text-sm uppercase tracking-wider mb-3">Get in touch</p>
          <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-5">
            Let's find out how AI can work for your business
          </h1>
          <p class="text-gray-500 text-lg leading-relaxed">
            Book a free 30-minute discovery call. We'll talk through your business, your goals, and whether — and how — I can help. No jargon, no hard sell, no pressure.
          </p>
        </div>
      </div>
    </section>

    <!-- Main content -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

          <!-- Left: info -->
          <div class="lg:col-span-2 space-y-8 reveal">

            <!-- What to expect -->
            <div class="bg-white rounded-2xl p-7 border border-gray-200 shadow-sm">
              <h2 class="font-bold text-gray-900 mb-5">What happens on the call</h2>
              <ol class="space-y-5">
                {[
                  { step: "1", title: "You share your situation", body: "Tell me about your business, your team, and what you're hoping AI could help with." },
                  { step: "2", title: "I share what I'm seeing", body: "Based on your context, I'll give you honest thoughts on where AI could realistically help and where it can't." },
                  { step: "3", title: "We agree on next steps", body: "If there's a good fit, we'll talk about options. If not, I'll say so — and point you in the right direction." },
                ].map((item) => (
                  <li class="flex items-start gap-4">
                    <div class="w-8 h-8 rounded-lg bg-brand-50 border border-brand-100 flex items-center justify-center flex-shrink-0">
                      <span class="text-brand-600 font-bold text-sm">{item.step}</span>
                    </div>
                    <div>
                      <p class="font-semibold text-gray-900 text-sm">{item.title}</p>
                      <p class="text-gray-500 text-sm leading-relaxed mt-0.5">{item.body}</p>
                    </div>
                  </li>
                ))}
              </ol>
            </div>

            <!-- Reassurances -->
            <div class="space-y-3">
              {[
                "30 minutes — no longer than needed",
                "No commitment or obligation whatsoever",
                "I reply to all enquiries within 1 business day",
                "If we're not a fit, I'll tell you honestly",
              ].map((item) => (
                <div class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full bg-brand-100 flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                  <span class="text-gray-600 text-sm">{item}</span>
                </div>
              ))}
            </div>

            <!-- Testimonial -->
            <figure class="bg-brand-50 border border-brand-100 rounded-2xl p-6">
              <blockquote class="text-gray-700 text-sm leading-relaxed mb-3 italic">
                "I booked the call half-expecting a sales pitch. Instead I got the most useful 30 minutes I'd spent on my business in months."
              </blockquote>
              <figcaption class="text-gray-500 text-xs font-medium">James Okafor — Founder, Okafor Property Services</figcaption>
            </figure>
          </div>

          <!-- Right: contact form -->
          <div class="lg:col-span-3 reveal reveal-delay-2">
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
              <h2 class="font-bold text-gray-900 text-lg mb-2">Send a message</h2>
              <p class="text-gray-500 text-sm mb-7">Fill in the form and I'll get back to you within 1 business day to arrange a time that works.</p>

              <form id="contact-form" class="space-y-5" novalidate>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                  <div>
                    <label for="firstName" class="block text-sm font-medium text-gray-700 mb-1.5">First name <span class="text-red-500">*</span></label>
                    <input
                      type="text"
                      id="firstName"
                      name="firstName"
                      required
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-transparent transition-shadow"
                      placeholder="Jane"
                    />
                  </div>
                  <div>
                    <label for="lastName" class="block text-sm font-medium text-gray-700 mb-1.5">Last name <span class="text-red-500">*</span></label>
                    <input
                      type="text"
                      id="lastName"
                      name="lastName"
                      required
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-transparent transition-shadow"
                      placeholder="Smith"
                    />
                  </div>
                </div>

                <div>
                  <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email address <span class="text-red-500">*</span></label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-transparent transition-shadow"
                    placeholder="jane@yourbusiness.com"
                  />
                </div>

                <div>
                  <label for="business" class="block text-sm font-medium text-gray-700 mb-1.5">Business name</label>
                  <input
                    type="text"
                    id="business"
                    name="business"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-transparent transition-shadow"
                    placeholder="Your business name"
                  />
                </div>

                <div>
                  <label for="teamSize" class="block text-sm font-medium text-gray-700 mb-1.5">Team size</label>
                  <select
                    id="teamSize"
                    name="teamSize"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-transparent transition-shadow bg-white text-gray-700"
                  >
                    <option value="" disabled selected>Select your team size</option>
                    <option value="solo">Just me</option>
                    <option value="2-5">2–5 people</option>
                    <option value="6-15">6–15 people</option>
                    <option value="16-50">16–50 people</option>
                    <option value="50+">50+ people</option>
                  </select>
                </div>

                <div>
                  <label for="service" class="block text-sm font-medium text-gray-700 mb-1.5">What are you interested in?</label>
                  <select
                    id="service"
                    name="service"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-transparent transition-shadow bg-white text-gray-700"
                  >
                    <option value="" disabled selected>Select a service</option>
                    <option value="workshops">AI Workshops & Team Training</option>
                    <option value="consulting">1:1 Strategy Consulting</option>
                    <option value="audit">AI Audit & Roadmap</option>
                    <option value="unsure">Not sure yet</option>
                  </select>
                </div>

                <div>
                  <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Tell me a bit about your situation <span class="text-red-500">*</span></label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="4"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-transparent transition-shadow resize-none"
                    placeholder="What's the main challenge you're hoping AI could help with? What have you already tried?"
                  ></textarea>
                </div>

                <!-- Error message -->
                <div id="form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm"></div>

                <button
                  type="submit"
                  id="submit-btn"
                  class="w-full flex items-center justify-center gap-2 px-6 py-4 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors shadow-sm disabled:opacity-60 disabled:cursor-not-allowed"
                >
                  <span id="btn-text">Send my message</span>
                  <svg id="btn-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                  </svg>
                  <svg id="btn-spinner" class="w-4 h-4 hidden animate-spin" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                  </svg>
                </button>

                <p class="text-center text-gray-400 text-xs">I respond to all messages within 1 business day.</p>
              </form>

              <!-- Success state -->
              <div id="form-success" class="hidden text-center py-10">
                <div class="w-16 h-16 rounded-full bg-brand-100 flex items-center justify-center mx-auto mb-5">
                  <svg class="w-8 h-8 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <h3 class="font-bold text-gray-900 text-lg mb-2">Message sent!</h3>
                <p class="text-gray-500 text-sm">Thanks for getting in touch. I'll reply within 1 business day to arrange a time for our call.</p>
              </div>
            </div>

            <!-- Alternative contact -->
            <p class="text-center text-sm text-gray-400 mt-5">
              Prefer email? Reach me directly at
              <a href="mailto:hello@humanapprovedai.com" class="text-brand-600 hover:text-brand-700 font-medium transition-colors">
                hello@humanapprovedai.com
              </a>
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form       = document.getElementById('contact-form') as HTMLFormElement;
  const successDiv = document.getElementById('form-success') as HTMLElement;
  const errorDiv   = document.getElementById('form-error') as HTMLElement;
  const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText    = document.getElementById('btn-text') as HTMLElement;
  const btnIcon    = document.getElementById('btn-icon') as HTMLElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    // Basic validation
    const required = form.querySelectorAll('[required]') as NodeListOf<HTMLInputElement | HTMLTextAreaElement>;
    let valid = true;
    required.forEach((field) => {
      if (!field.value.trim()) {
        field.classList.add('border-red-300', 'ring-1', 'ring-red-300');
        valid = false;
      } else {
        field.classList.remove('border-red-300', 'ring-1', 'ring-red-300');
      }
    });

    if (!valid) {
      errorDiv.textContent = 'Please fill in all required fields.';
      errorDiv.classList.remove('hidden');
      return;
    }

    // Email format check
    const email = (document.getElementById('email') as HTMLInputElement).value;
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorDiv.textContent = 'Please enter a valid email address.';
      errorDiv.classList.remove('hidden');
      return;
    }

    // Loading state
    submitBtn.disabled = true;
    btnText.textContent = 'Sending...';
    btnIcon.classList.add('hidden');
    btnSpinner.classList.remove('hidden');

    // Simulate submission (replace with your form endpoint — e.g. Formspree or Netlify Forms)
    await new Promise((resolve) => setTimeout(resolve, 1200));

    // Show success
    form.classList.add('hidden');
    successDiv.classList.remove('hidden');
  });
</script>
