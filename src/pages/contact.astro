---
import BaseLayout from "../layouts/BaseLayout.astro";
import { industries, SITE } from "../data/site";
---

<BaseLayout
  title="Contact"
  description="Book a free call to see where AI could help your team without creating a mess."
>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Contact</p>
      <h1>Book a free call.</h1>
      <p>
        Tell us where your team spends the most time and where AI feels useful
        but risky. We'll figure out which tasks are worth tackling first and
        whether a session makes sense.
      </p>
      <div class="button-row">
        <a class="button" href="#quick-enquiry">Use the enquiry form</a>
        <a class="button button-secondary" href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </div>
    </div>
    <form id="quick-enquiry" class="panel panel-pad" name="contact">
      <p class="eyebrow">Quick enquiry</p>
      <label>
        Name
        <input name="name" autocomplete="name" required />
      </label>
      <label>
        Email
        <input name="email" type="email" autocomplete="email" required />
      </label>
      <label>
        Company
        <input name="company" autocomplete="organization" />
      </label>
      <label>
        Industry
        <select name="industry" required>
          <option value="">Choose one</option>
          {industries.map((industry) => <option value={industry.slug}>{industry.title}</option>)}
        </select>
      </label>
      <label>
        Team size
        <input name="team-size" />
      </label>
      <label>
        Where does your team spend the most time, and what would you want AI to help with?
        <textarea name="time-drain" rows="5"></textarea>
      </label>
      <button class="button" type="submit">Send enquiry</button>
    </form>
  </section>
</BaseLayout>

<script define:vars={{ email: SITE.email }}>
  const form = document.getElementById("quick-enquiry");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();

    const data = new FormData(form);
    const subject = `Human Approved AI enquiry from ${data.get("company") || data.get("name") || "website"}`;
    const body = [
      `Name: ${data.get("name") || ""}`,
      `Email: ${data.get("email") || ""}`,
      `Company: ${data.get("company") || ""}`,
      `Industry: ${data.get("industry") || ""}`,
      `Team size: ${data.get("team-size") || ""}`,
      "",
      "Where the time goes / AI help wanted:",
      `${data.get("time-drain") || ""}`,
    ].join("\n");

    window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });
</script>

<style>
  form {
    display: grid;
    gap: 16px;
  }

  label {
    display: grid;
    gap: 8px;
    color: var(--muted);
    font-weight: 700;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 2px solid var(--ink);
    border-radius: 16px;
    background: var(--paper-soft);
    color: var(--ink);
    font: inherit;
    padding: 12px 14px;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: 3px solid var(--amber);
    outline-offset: 2px;
  }

  button {
    cursor: pointer;
  }
</style>
