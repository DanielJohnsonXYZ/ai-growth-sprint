---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../data/site";
---

<BaseLayout
  title="Request a free AI adoption call"
  description="A practical conversation about your business, your priorities, and where AI can create real value. No commitment, no jargon."
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Book a Call</p>
      <h1>Let's Find Where AI Fits Your Business</h1>
      <p>
        A practical conversation about your business, your priorities, and where
        AI can create real value. No commitment. No jargon. No product pitch.
      </p>
      <div class="button-row">
        <a class="button" href="#enquiry-form">Get in touch</a>
        <a class="button button-secondary" href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </div>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">What to expect</p>
      <h2>A useful conversation, whatever you decide.</h2>
      <p class="lead">We'll look at your business honestly. If AI can help, we'll say how. If it can't, we'll say that too.</p>
    </aside>
  </section>

  <!-- WHAT HAPPENS ON THE CALL -->
  <section class="section">
    <div class="section-header">
      <p class="eyebrow">On the call</p>
      <h2>What we cover in 30 minutes.</h2>
    </div>
    <div class="grid grid-4">
      {([
        ["Understand your situation", "We listen first. What your business does, how your team works, and where time gets lost."],
        ["Identify quick wins", "We point to the 2–3 areas where AI is most likely to save time or create value for you specifically."],
        ["Discuss risks", "We talk through what to avoid, what needs human oversight, and what's genuinely not ready yet."],
        ["Recommend next steps", "You leave with a clear sense of what to do first — whether that's working with us or not."],
      ] as const).map(([title, body]) => (
        <article class="card">
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ENQUIRY FORM -->
  <section class="section section-tight">
    <form id="enquiry-form" class="panel panel-pad" name="contact">
      <div class="section-header">
        <p class="eyebrow">Quick enquiry</p>
        <h2>Tell us about your business.</h2>
        <p>We'll get back to you within one working day to arrange a call.</p>
      </div>
      <div class="form-grid">
        <label>
          Name
          <input name="name" autocomplete="name" required />
        </label>
        <label>
          Email
          <input name="email" type="email" autocomplete="email" required />
        </label>
        <label>
          Company
          <input name="company" autocomplete="organization" />
        </label>
        <label>
          Industry
          <select name="industry">
            <option value="">Choose one</option>
            <option value="accounting">Accounting</option>
            <option value="recruitment">Recruitment</option>
            <option value="legal">Legal</option>
            <option value="property">Property</option>
            <option value="manufacturing">Manufacturing</option>
            <option value="agency">Agency</option>
            <option value="other">Other</option>
          </select>
        </label>
        <label class="full-width">
          What's taking the most time, and what would you want AI to help with?
          <textarea name="context" rows="5"></textarea>
        </label>
      </div>
      <!-- Honeypot: leave empty (spam bots often fill hidden fields) -->
      <label class="form-hp" aria-hidden="true">
        <span>Company website (optional)</span>
        <input name="company_website" type="text" tabindex="-1" autocomplete="off" />
      </label>
      <p class="form-privacy">
        By sending this enquiry, you agree that we may contact you about your
        request. We will not add you to a mailing list unless you ask us to. See
        our <a href="/privacy/">privacy policy</a>.
      </p>
      <button class="button" type="submit">Send enquiry</button>
    </form>
  </section>
</BaseLayout>

<script define:vars={{ email: SITE.email }}>
  const form = document.getElementById("enquiry-form");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();

    const data = new FormData(form);
    const hp = (data.get("company_website") as string)?.trim();
    if (hp) {
      return;
    }
    const subject = `Human Approved AI enquiry from ${data.get("company") || data.get("name") || "website"}`;
    const body = [
      `Name: ${data.get("name") || ""}`,
      `Email: ${data.get("email") || ""}`,
      `Company: ${data.get("company") || ""}`,
      `Industry: ${data.get("industry") || ""}`,
      "",
      "Context / what they need help with:",
      `${data.get("context") || ""}`,
    ].join("\n");

    window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  });
</script>

<style>
  .form-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: 1fr 1fr;
    margin-bottom: 24px;
  }

  .full-width {
    grid-column: 1 / -1;
  }

  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }

  label {
    display: grid;
    gap: 8px;
    color: var(--muted);
    font-weight: 700;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 2px solid var(--ink);
    border-radius: 16px;
    background: var(--paper-soft);
    color: var(--ink);
    font: inherit;
    padding: 12px 14px;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: 3px solid var(--amber);
    outline-offset: 2px;
  }

  button {
    cursor: pointer;
  }

  .form-hp {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .form-privacy {
    margin: 0 0 20px;
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.5;
    max-width: 52ch;
  }

  .form-privacy a {
    color: var(--moss);
    font-weight: 700;
  }
</style>
