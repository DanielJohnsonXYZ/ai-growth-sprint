---
import BaseLayout from "../layouts/BaseLayout.astro";
import { industries, packages, priorityIndustries, SITE, useCases } from "../data/site";

const featuredUseCases = useCases.filter((useCase) =>
  ["proposals-and-tenders", "client-reporting", "documentation-and-sops"].includes(useCase.slug),
);
const schema = {
  "@type": "Service",
  name: "AI workflow training for UK SME teams",
  provider: { "@type": "Organization", name: SITE.name, url: SITE.url },
  areaServed: "United Kingdom",
  serviceType: "AI training and workflow implementation",
};
---

<BaseLayout
  title="Practical AI Training for UK SME Teams"
  description="Save hours every week on repetitive admin with practical AI training for UK SME teams. Built around real work, safe review, and human sign-off."
  schema={schema}
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Human Approved AI for UK SME teams</p>
      <h1>Save hours every week on repetitive admin.</h1>
      <p>
        Practical AI training for busy teams that want time back, better first
        drafts, and clearer workflows without lowering standards or handing
        decisions to a tool.
      </p>
      <div class="hero-actions">
        <a class="button" href="/contact/">Book a free call</a>
        <a class="button button-secondary" href="/how-it-works/">See how it works</a>
      </div>
    </div>
    <aside class="panel panel-pad proof-meter" aria-label="What your team gets">
      <p class="eyebrow">Start with business results</p>
      <h2>We show you where AI makes or saves money first.</h2>
      <div class="stat-stack">
        <div><span>Admin</span><strong>Cut repetitive work that eats the week</strong></div>
        <div><span>Output</span><strong>Get first drafts faster, then review properly</strong></div>
        <div><span>Control</span><strong>Keep final decisions with your team</strong></div>
      </div>
      <p class="proof-note">Your team reviews everything before it goes out. No handing work over to a tool and hoping for the best.</p>
    </aside>
  </section>

  <section class="section section-tight trust-ribbon" aria-label="Who we work with">
    <p><strong>We work with teams where a lot of time is spent on documents, communication, and coordination.</strong> Construction, accounting, and property are where we have the most experience.</p>
    <div class="tag-list" aria-label="Priority sectors">
      <span class="tag">Construction</span>
      <span class="tag">Accounting</span>
      <span class="tag">Property</span>
    </div>
  </section>

  <section class="section chapter">
    <div class="section-header">
      <p class="eyebrow">What this actually helps with</p>
      <h2>Most teams do not need another tool. They need a faster way to get through the work they already have.</h2>
      <p>
        Here are the areas where this usually makes a difference.
      </p>
    </div>
    <div class="grid grid-3">
      {([
        ["Proposals and tenders", "Put together a solid first draft without starting from a blank page every time."],
        ["Client reports", "Turn notes, calls, and updates into something structured your team can review and send."],
        ["Follow-ups", "Write replies faster without everything sounding the same."],
        ["Internal processes", "Turn rough notes into clear steps people can actually follow."],
        ["Research", "Pull together a first pass instead of spending hours gathering everything manually."],
        ["Admin", "Cut down the repetitive work that slows projects down."],
      ] as const).map(([title, body], index) => (
        <article class={index < 3 ? "card card-featured card-interactive" : "card card-quiet"}>
          <p class="eyebrow">{index + 1 < 10 ? `0${index + 1}` : index + 1}</p>
          <strong>{title}</strong>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight">
    <div class="section-header">
      <p class="eyebrow">Who this is for</p>
      <h2>Teams where a lot of time is spent on documents, communication, and coordination.</h2>
    </div>
    <div class="grid grid-3">
      {([
        { industry: priorityIndustries.find(i => i.slug === "construction"), line: "Less time rebuilding tenders and paperwork under pressure." },
        { industry: priorityIndustries.find(i => i.slug === "accounting"), line: "Less time on reporting, more time on client work that actually matters." },
        { industry: priorityIndustries.find(i => i.slug === "property"), line: "Faster listings, updates, and follow-ups without losing quality." },
      ] as const).map(({ industry, line }) => industry && (
        <article class="card highlight card-interactive">
          <p class="eyebrow">{industry.shortName}</p>
          <h3>{industry.shortName}</h3>
          <p>{line}</p>
          <a href={`/industries/${industry.slug}/`}>See {industry.shortName.toLowerCase()} examples</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">How it works</p>
      <h2>Clear next steps, no jargon.</h2>
      <p>
        We look at your day-to-day tasks and show you where AI actually saves
        time, where it doesn't, and what should be checked properly before
        anything is sent out. Everything is based on your real work, not
        generic examples.
      </p>
    </div>
    <div class="grid grid-4">
      {([
        ["1", "Free call", "You tell us where the time goes and what feels risky."],
        ["2", "Identify AI opportunities", "We find the tasks where AI can save money, make money, or free the team up."],
        ["3", "Tailored training", "Your team works on real documents, emails, reports, and admin tasks."],
        ["4", "Human-approved workflows", "You leave with reusable prompts, approval rules, and a safer way to keep using AI."],
      ] as const).map(([step, title, body]) => (
        <article class="card">
          <p class="eyebrow">Step {step}</p>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
    <div class="button-row" style="margin-top: 28px">
      <a class="button button-secondary" href="/how-it-works/">More about how it works</a>
    </div>
  </section>

  <section class="section">
    <div class="split">
      <div class="section-header">
        <p class="eyebrow">Where teams usually use it</p>
        <h2>Some teams think in terms of industry, others in terms of tasks.</h2>
        <p>
          These come up across most businesses we work with.
        </p>
      </div>
      <div class="grid">
        {featuredUseCases.map((useCase) => (
          <article class="card card-interactive">
            <h3>{useCase.title}</h3>
            <p>{useCase.slug === "proposals-and-tenders"
              ? "Getting to a first draft quickly so your team can focus on refining it."
              : useCase.slug === "client-reporting"
              ? "Turning scattered information into something clear and usable."
              : "Writing things down properly without it turning into a time drain."}</p>
            <a href={`/use-cases/${useCase.slug}/`}>See examples</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <p class="eyebrow">Keeping things under control</p>
      <h2>You're not handing work over to a tool and hoping for the best.</h2>
        <p>
          AI helps speed things up, but your team still reviews anything
          important before it goes out. You'll also be clear on what shouldn't
          be shared with public tools, where accuracy matters most, and how to
          keep tone and standards consistent.
        </p>
      </div>
      <div class="button-row">
        <a class="button" href="/trust-security/">How we handle trust and security</a>
        <a class="button button-secondary" href="/results/">See results so far</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Ways to work together</p>
      <h2>Three options, depending on what your team needs.</h2>
    </div>
    <div class="grid grid-3">
      {packages.map((item, index) => (
        <article class={index === 0 ? "card pricing-card recommended" : "card pricing-card"}>
          {index === 0 && <span class="badge">Most teams start here</span>}
          <h3>{item.name}</h3>
          <strong class="price">{item.price}</strong>
          <p>{item.fit}</p>
          <ul class="checklist">
            {item.includes.map((line) => <li>{line}</li>)}
          </ul>
        </article>
      ))}
    </div>
    <div class="button-row" style="margin-top: 28px">
      <a class="button" href="/pricing/">Compare options</a>
      <a class="button button-secondary" href="/contact/">Book a free call</a>
    </div>
  </section>

  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
      <h2>Most teams try AI a couple of times, then go back to doing things the old way.</h2>
        <p>
          The difference here is simple — this is built around the work your
          team is already doing, so it actually gets used.
        </p>
      </div>
      <a class="button" href="/contact/">Book a free call</a>
    </div>
  </section>
</BaseLayout>
