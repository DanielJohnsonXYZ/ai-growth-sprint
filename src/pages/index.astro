---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@type": "Service",
  name: "AI training and workflow adoption for UK SMEs",
  provider: { "@type": "Organization", name: "Human Approved AI", url: "https://humanapprovedai.com" },
  areaServed: "United Kingdom",
  serviceType: "AI training, workflow implementation, and strategy",
  mainEntityOfPage: {
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Do you sell software?",
        acceptedAnswer: { "@type": "Answer", text: "No. We're a consultancy. We help you use the right tools, not sell you one." }
      },
      {
        "@type": "Question",
        name: "Is this safe for client data?",
        acceptedAnswer: { "@type": "Answer", text: "Yes. We never put sensitive client data into public AI tools without your explicit approval and proper safeguards." }
      },
      {
        "@type": "Question",
        name: "Do you work with ChatGPT or Copilot?",
        acceptedAnswer: { "@type": "Answer", text: "Yes. We work with the tools that fit your business and team." }
      },
      {
        "@type": "Question",
        name: "Can you train non-technical teams?",
        acceptedAnswer: { "@type": "Answer", text: "Absolutely. We specialise in practical training for everyday business users." }
      },
      {
        "@type": "Question",
        name: "What happens on the discovery call?",
        acceptedAnswer: { "@type": "Answer", text: "We discuss your business, identify quick wins, and recommend next steps. No commitment." }
      },
      {
        "@type": "Question",
        name: "How do you measure success?",
        acceptedAnswer: { "@type": "Answer", text: "Time saved, workflows implemented, and team confidence using AI independently." }
      },
      {
        "@type": "Question",
        name: "What do we get after the workshop?",
        acceptedAnswer: { "@type": "Answer", text: "Trained team, prompt library, and clear approval rules for ongoing use." }
      },
    ]
  }
};
---

<BaseLayout
  title="Human Approved AI | AI Training & Workflow Adoption for UK SMEs"
  description="Practical AI training, workflow systems, and strategy support for UK SMEs. Helping businesses adopt AI properly."
  schema={schema}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-copy">
      <h1>Turn scattered AI experiments into workflows your team actually uses.</h1>
      <p>
        We help UK SMEs find where AI saves real time, train teams on real work,
        and build simple systems for admin, reports, proposals, emails, and internal knowledge.
      </p>
      <div class="hero-actions">
        <a class="button" href="/contact/" data-cta="hero-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
        <a class="button button-secondary" href="/services/" data-cta="hero-services">See Services</a>
      </div>
    </div>
    <aside class="panel panel-pad proof-meter" aria-label="What you get">
      <p class="eyebrow">No jargon. No chaos.</p>
      <h2>Helping business owners and teams use AI without expensive mistakes.</h2>
      <div class="stat-stack">
        <div><span>1. We assess</span><strong>Find where AI saves real time</strong></div>
        <div><span>2. We train</span><strong>Team confidence and adoption built in</strong></div>
        <div><span>3. We support</span><strong>Ongoing guidance to keep momentum</strong></div>
      </div>
      <p class="proof-note">This is practical consultancy for established businesses, not software demos or generic theory.</p>
    </aside>
  </section>

  <!-- IMMEDIATE PROOF (hero follow-on) -->
  <section class="section section-tight hero-proof-after" aria-label="Why Human Approved AI">
    <div class="panel panel-pad card-quiet">
      <p class="eyebrow">Practical consultancy, not a generic AI landing page</p>
      <ul class="checklist">
        <li><strong>Founder-led</strong> — you get experienced guidance on adoption, training, and workflows.</li>
        <li><strong>UK SMEs</strong> — workshops and implementation for teams doing real admin, sales, and ops work.</li>
        <li><strong>Honest proof</strong> — we describe outcomes plainly; we do not inflate metrics or borrow unrelated credibility.</li>
      </ul>
      <p class="proof-note" style="margin-top: 18px">
        Built for UK SME teams in <strong>accounting, recruitment, property, construction, and operations</strong>
        — see <a href="/industries/">industries</a> for how we tailor by sector.
      </p>
      <div class="button-row" style="margin-top: 22px">
        <a class="button button-secondary" href="/about/" data-cta="hero-proof-about">About</a>
        <a class="button button-secondary" href="/results/" data-cta="hero-proof-results">How we show proof</a>
      </div>
    </div>
  </section>

  <!-- WHAT WE ACTUALLY HELP WITH -->
  <section class="section">
    <div class="section-header">
      <p class="eyebrow">What we actually help with</p>
      <h2>Workflows that save real time</h2>
    </div>
    <div class="grid grid-3">
      {([
        ["Proposal writing", "Turn your scope and case studies into tailored first drafts your team reviews."],
        ["Client reports", "Transform notes and data into readable narratives for client approval."],
        ["Sales follow-ups", "Prepare timely, personalized follow-ups from CRM notes."],
        ["Internal knowledge search", "Make your documents searchable and useful with AI assistants."],
        ["Meeting notes to actions", "Turn meeting transcripts into structured action items."],
        ["AI policy and safe usage", "Create clear rules for your team on what AI can and cannot do."],
        ["Recruitment/admin workflows", "Streamline candidate outreach, onboarding, and document processes."],
      ] as const).map(([title, body]) => (
        <article class="card card-interactive">
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="section section-tight trust-ribbon" aria-label="Trust strip">
    <p><strong>Helping business owners and teams use AI without jargon, chaos, or expensive mistakes.</strong></p>
    <a href="/about/" class="button button-secondary" style="margin-left: auto;">About us</a>
  </section>

  <!-- PROBLEM SECTION -->
  <section class="section chapter">
    <div class="section-header">
      <h2>Most businesses know AI matters. Very few know what to do next.</h2>
      <p>
        You may have tested ChatGPT. Your team may be experimenting randomly.
        Competitors may be talking about AI. But without a clear plan, most
        businesses waste time, confuse staff, and adopt the wrong tools.
      </p>
      <p><strong>We help you turn AI into something practical, useful, and profitable.</strong></p>
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <section class="section">
    <div class="section-header">
      <p class="eyebrow">How we help</p>
      <h2>How We Help</h2>
    </div>
    <div class="grid grid-4">
      {([
        ["AI Training", "Practical workshops that help teams use AI confidently."],
        ["Workflow Systems", "Reduce repetitive admin and improve internal efficiency."],
        ["Leadership Strategy", "Clear direction on where AI creates ROI."],
        ["Ongoing Support", "Monthly guidance, training, and optimisation."],
      ] as const).map(([title, body]) => (
        <article class="card card-featured card-interactive">
          <strong>{title}</strong>
          <p>{body}</p>
        </article>
      ))}
    </div>
    <div class="button-row" style="margin-top: 28px">
      <a class="button button-secondary" href="/services/" data-cta="services-preview">See All Services</a>
    </div>
  </section>

  <!-- WORKFLOW DIAGRAM -->
  <section class="section">
    <div class="section-header">
      <p class="eyebrow">How it works visually</p>
      <h2>Your workflow, step by step.</h2>
    </div>
    <div class="workflow-diagram">
      <div class="workflow-step">
        <h3>1. Current state</h3>
        <p>Map where the time goes now</p>
      </div>
      <div class="workflow-arrow">→</div>
      <div class="workflow-step">
        <h3>2. AI drafts</h3>
        <p>First pass created by AI</p>
      </div>
      <div class="workflow-arrow">→</div>
      <div class="workflow-step">
        <h3>3. Human review</h3>
        <p>Your team checks and approves</p>
      </div>
      <div class="workflow-arrow">→</div>
      <div class="workflow-step">
        <h3>4. Ready to go</h3>
        <p>Final output, human-approved</p>
      </div>
    </div>
  </section>

  <!-- RESULTS SECTION -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <p class="eyebrow">What good AI adoption looks like</p>
        <h2>What Good AI Adoption Looks Like</h2>
      </div>
      <ul class="checklist">
        <li>Save hours every week</li>
        <li>Faster proposals, emails, reports, and admin</li>
        <li>Better internal systems</li>
        <li>Stronger team productivity</li>
        <li>Less wasted experimentation</li>
        <li>Clear commercial value</li>
      </ul>
      <div class="button-row" style="margin-top: 24px">
        <a class="button button-secondary" href="/results/" data-cta="results-preview">See Results</a>
      </div>
    </div>
  </section>

  <!-- PROCESS SECTION -->
  <section class="section">
    <div class="section-header">
      <p class="eyebrow">How it works</p>
      <h2>How It Works</h2>
    </div>
    <div class="grid grid-4">
      {([
        ["Step 1", "Discovery Call", "We understand your business and bottlenecks."],
        ["Step 2", "Opportunity Plan", "We identify quick wins and priorities."],
        ["Step 3", "Training + Implementation", "We train your people and improve workflows."],
        ["Step 4", "Ongoing Growth", "Optional retained support to keep momentum."],
      ] as const).map(([step, title, body]) => (
        <article class="card">
          <p class="eyebrow">{step}</p>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- INDUSTRIES PREVIEW -->
  <section class="section section-tight">
    <div class="section-header">
      <p class="eyebrow">Who this is for</p>
      <h2>We tailor AI adoption to how your business operates.</h2>
    </div>
    <div class="grid grid-3">
      {([
        ["Accountants", "Reduce admin, improve client comms, streamline documents."],
        ["Recruitment", "Candidate outreach, job ad creation, CRM workflows."],
        ["Legal", "Drafting support, admin efficiency, internal knowledge tools."],
        ["Property", "Enquiries, listings, marketing, operations."],
        ["Manufacturing", "Reporting, SOPs, admin processes."],
        ["Agencies", "Delivery systems, sales workflows, content operations."],
      ] as const).map(([title, body]) => (
        <article class="card card-interactive">
          <p class="eyebrow">{title}</p>
          <strong>{title}</strong>
          <p>{body}</p>
        </article>
      ))}
    </div>
    <div class="button-row" style="margin-top: 28px">
      <a class="button button-secondary" href="/industries/" data-cta="industries-preview">See All Industries</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-tight">
    <div class="section-header">
      <h2>Frequently asked questions</h2>
    </div>
    <div class="grid grid-2">
      {[
        ["Do you sell software?", "No. We're a consultancy. We help you use the right tools, not sell you one."],
        ["Is this safe for client data?", "Yes. We never put sensitive client data into public AI tools without your explicit approval and proper safeguards."],
        ["Do you work with ChatGPT or Copilot?", "Yes. We work with the tools that fit your business and team."],
        ["Can you train non-technical teams?", "Absolutely. We specialise in practical training for everyday business users."],
        ["What happens on the discovery call?", "We discuss your business, identify quick wins, and recommend next steps. No commitment."],
        ["How do you measure success?", "Time saved, workflows implemented, and team confidence using AI independently."],
        ["What do we get after the workshop?", "Trained team, prompt library, and clear approval rules for ongoing use."],
      ].map(([q, a]) => (
        <details class="faq-item">
          <summary>{q}</summary>
          <p>{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <h2>AI doesn't need to be confusing.</h2>
        <p>
          If your business knows AI matters but doesn't know where to begin,
          we'll make it simple.
        </p>
      </div>
      <a class="button" href="/contact/" data-cta="final-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
    </div>
  </section>
</BaseLayout>
