---
import BaseLayout from "../layouts/BaseLayout.astro";
import { industries, packages, priorityIndustries, SITE, useCases } from "../data/site";

const featuredUseCases = useCases.filter((useCase) =>
  ["proposals-and-tenders", "client-reporting", "documentation-and-sops"].includes(useCase.slug),
);
const primaryOutcomes = [
  "Create proposal and tender first passes",
  "Turn notes into client-ready reports",
  "Prepare follow-ups that do not sound generic",
];
const schema = {
  "@type": "Service",
  name: "AI workflow training for UK SME teams",
  provider: { "@type": "Organization", name: SITE.name, url: SITE.url },
  areaServed: "United Kingdom",
  serviceType: "AI training and workflow implementation",
};
---

<BaseLayout
  title="Safe AI Adoption for UK SME Teams"
  description="Practical AI adoption training for UK SME teams that need safe, repeatable workflows, human quality control, and habits that stick."
  schema={schema}
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Safe AI adoption for 10-50 person UK SMEs</p>
      <h1>Make AI safe enough to stick.</h1>
      <p>
        We help founders and ops leads introduce AI without bad outputs reaching
        clients, sensitive data leaking into tools, or training being forgotten
        by Monday. Your team leaves with practical rules, real workflows, and a
        quality-control system they can keep using.
      </p>
      <div class="hero-actions">
        <a class="button" href="/contact/">Book a free 15-minute call</a>
        <a class="button button-secondary" href="/how-it-works/">See how it works</a>
      </div>
    </div>
    <aside class="panel panel-pad proof-meter" aria-label="Trust and workflow examples">
      <p class="eyebrow">Rules before tools</p>
      <h2>AI prepares. People approve.</h2>
      <div class="stat-stack">
        <div><span>Client-facing work</span><strong>Human sign-off</strong></div>
        <div><span>Sensitive data</span><strong>Safe summaries only</strong></div>
        <div><span>Workshop day</span><strong>Monday workflows</strong></div>
      </div>
      <p class="proof-note">This is not tool training. It is a safe operating system for AI adoption.</p>
    </aside>
  </section>

  <section class="section section-tight trust-ribbon" aria-label="Trust principles">
    <p><strong>Built for cautious operators:</strong> stop bad outputs, protect sensitive data, and turn AI into a working habit instead of a one-day novelty.</p>
    <div class="tag-list" aria-label="Priority proof sectors">
      <span class="tag">Construction</span>
      <span class="tag">Accounting</span>
      <span class="tag">Property</span>
    </div>
  </section>

  <section class="section chapter">
    <div class="section-header">
      <p class="eyebrow">Outcomes before tools</p>
      <h2>Start with the risks that make teams hesitate.</h2>
      <p>
        The training is about adoption that sticks: when to use AI, when not to,
        what never goes into public tools, and how people keep control of tone,
        facts, commitments, and professional judgment.
      </p>
    </div>
    <div class="grid grid-3">
      {([
        ["Create proposal and tender first passes", "Stop rebuilding from old docs under deadline pressure."],
        ["Turn notes into client-ready reports", "Prepare management commentary, progress reports, and market updates faster."],
        ["Prepare follow-ups that do not sound generic", "Send timely, on-tone messages without typing each one from scratch."],
        ["Create SOPs from messy process notes", "Capture process knowledge before it walks out the door."],
        ["Summarize research into useful briefings", "Compress a morning of research into a first-pass brief for review."],
        ["Build onboarding and admin checklists", "Reduce the repeated setup work that delays new clients and projects."],
      ] as const).map(([title, body], index) => (
        <article class={primaryOutcomes.includes(title) ? "card card-featured card-interactive" : "card card-quiet"}>
          <p class="eyebrow">{index + 1 < 10 ? `0${index + 1}` : index + 1}</p>
          <strong>{title}</strong>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight">
    <div class="section-header">
      <p class="eyebrow">Industries we work with</p>
      <h2>Built for teams that run on paperwork, not products.</h2>
      <p>
        We work with office-heavy industries where the admin load is high
        and the return on saved hours is easy to measure.
      </p>
    </div>
    <div class="grid grid-3">
      {priorityIndustries.map((industry) => (
        <article class="card highlight card-interactive">
          <p class="eyebrow">{industry.shortName}</p>
          <h3>{industry.shortName}</h3>
          <p>{industry.hero}</p>
          <p class="mini-proof">{industry.proofNote}</p>
          <a href={`/industries/${industry.slug}/`}>View industry page</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="split">
      <div class="section-header">
        <p class="eyebrow">Common workflows</p>
        <h2>Some teams search by task, not industry.</h2>
        <p>
          These workflows show up across multiple sectors. If the task
          sounds familiar, the training will help.
        </p>
      </div>
      <div class="grid">
        {featuredUseCases.map((useCase) => (
          <article class="card card-interactive">
            <h3>{useCase.title}</h3>
            <p>{useCase.problem}</p>
            <a href={`/use-cases/${useCase.slug}/`}>Explore workflow</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <p class="eyebrow">Built-in safeguards</p>
        <h2>AI prepares. People approve. That is the rule.</h2>
        <p>
          Every workflow includes clear approval boundaries. The workshop teaches
          where AI helps, what never to paste into public tools, and when human
          judgment is non-negotiable, especially for legal, accounting, healthcare,
          property, and other trust-sensitive teams.
        </p>
      </div>
      <div class="button-row">
        <a class="button" href="/trust-security/">Read trust and security</a>
        <a class="button button-secondary" href="/results/">See proof system</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Packages</p>
      <h2>Three ways to buy, one clear next step.</h2>
      <p>
        Choose by team size, depth of support, and how much customization
        you need. Every option starts with a free call.
      </p>
    </div>
    <div class="grid grid-3">
      {packages.map((item, index) => (
        <article class={index === 0 ? "card pricing-card recommended" : "card pricing-card"}>
          {index === 0 && <span class="badge">Recommended first</span>}
          <h3>{item.name}</h3>
          <strong class="price">{item.price}</strong>
          <p>{item.fit}</p>
          <ul class="checklist">
            {item.includes.map((line) => <li>{line}</li>)}
          </ul>
        </article>
      ))}
    </div>
    <div class="button-row" style="margin-top: 28px">
      <a class="button" href="/pricing/">Compare packages</a>
      <a class="button button-secondary" href="/contact/">Book the call</a>
    </div>
  </section>
</BaseLayout>
