---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const testimonials = [
  {
    quote: "We went from zero AI adoption to the whole team using it daily in under six weeks. It's saved us at least a day of admin work every week.",
    name: "Sarah Mitchell",
    role: "Director",
    company: "Mitchell & Co Accountants",
    initials: "SM",
  },
  {
    quote: "I'd tried to figure out AI on my own for months. One strategy session with Human Approved AI gave me a clear roadmap. Wish I'd done it sooner.",
    name: "James Okafor",
    role: "Founder",
    company: "Okafor Property Management",
    initials: "JO",
  },
];

const steps = [
  {
    number: "01",
    title: "Free Discovery Call",
    description: "We talk through your business, your team, and your goals. No jargon, no hard sell — just a real conversation to understand where AI can help.",
  },
  {
    number: "02",
    title: "Your Custom Plan",
    description: "Based on your situation, I build a tailored training or consulting plan — the right tools, the right approach, at the right pace for your team.",
  },
  {
    number: "03",
    title: "Training & Ongoing Support",
    description: "We implement together. Your team learns by doing, and I stay available to support adoption, answer questions, and adjust as you grow.",
  },
];

const services = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>`,
    title: "AI Workshops & Team Training",
    description: "Hands-on sessions built around your actual tasks. Your team leaves using AI the same day — not watching demos of tools they'll never touch again.",
    href: "/services/workshops",
    price: "From £1,500",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    title: "1:1 Strategy Consulting",
    description: "A trusted AI advisor who knows your business, not just the technology. We build your roadmap, choose your tools, and work through implementation together.",
    href: "/services/consulting",
    price: "From £2,500",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
    title: "AI Audit & Roadmap",
    description: "Not sure where to start? A structured audit uncovers exactly where AI would save the most time — with a written plan you can act on immediately.",
    href: "/services/audit",
    price: "From £950",
  },
];

const resources = [
  {
    type: "Guide",
    title: "AI for UK SMEs in 2026",
    desc: "What actually works for small businesses right now — practical tools, common mistakes, and where to start.",
    href: "/resources",
  },
  {
    type: "Template",
    title: "AI Policy Template for Small Businesses",
    desc: "A ready-to-use AI usage policy covering data handling, approval steps, and acceptable use. Adapt it in an afternoon.",
    href: "/resources",
  },
  {
    type: "Guide",
    title: "How to Train Your Team on AI",
    desc: "A practical framework for getting your team using AI confidently — without chaos, compliance risk, or confusion.",
    href: "/resources",
  },
];

const faqs = [
  {
    q: "Is AI safe for our client data?",
    a: "Yes — when it's set up properly. Before anything starts, we agree exactly what can be drafted in AI, what must be redacted, and what stays entirely in your own systems. Every workflow is designed around UK data handling guidance and ICO requirements. Nothing client-facing goes out without a human reviewer signing off.",
  },
  {
    q: "My team isn't technical at all. Will this actually work for them?",
    a: "This is the most common concern I hear — and it's almost always unfounded. If your team can use email and Google, they can use these tools. I've run workshops where the average age was 50+ and staff had refused new software before. By the end of the day, they were using AI independently. Sessions use your real tasks, not abstract demos.",
  },
  {
    q: "Will this work for my industry?",
    a: "I work across accounting, property, legal, construction, recruitment, agencies, and more. The tools are the same; the workflows are tailored. If you're unsure whether your sector is a fit, the free discovery call is the honest answer — I'd rather tell you it's not a good time than sell you something that doesn't deliver.",
  },
  {
    q: "How quickly will we see results?",
    a: "Workshop clients typically get useful AI drafts on their own work during the session itself. Measurable time savings — the kind that show up in capacity and margin — usually appear within four to six weeks of consistent use. The audit delivers a written report within five business days of the intake call.",
  },
];
---

<Layout
  title="AI Training & Consulting for Small Businesses | Daniel Johnson"
  description="Human Approved AI helps UK small and mid-size businesses adopt AI practically — with human approval built into every workflow. Book a free discovery call with Daniel Johnson."
>
  <Header />

  <main>

    <!-- ── HERO ──────────────────────────────────────────────────── -->
    <section class="relative bg-white overflow-hidden pt-16 pb-20 lg:pt-24 lg:pb-32">
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-brand-50 opacity-70 blur-3xl"></div>
        <div class="absolute bottom-0 -left-20 w-80 h-80 rounded-full bg-brand-100 opacity-40 blur-3xl"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
          <div class="max-w-2xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-brand-50 border border-brand-100 rounded-full text-brand-700 text-sm font-medium mb-6">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-500"></span>
              UK-based · Human-in-the-loop AI adoption
            </div>

            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 tracking-tight leading-tight mb-6">
              AI is only as useful<br/>
              as the person<br/>
              <span class="text-brand-600">who checks the output.</span>
            </h1>

            <p class="text-lg sm:text-xl text-gray-600 leading-relaxed max-w-2xl mb-4">
              I'm Daniel Johnson. I help UK small businesses build AI workflows where your team stays in control — and the time savings actually show up.
            </p>
            <p class="text-base text-gray-500 leading-relaxed max-w-xl mb-8">
              No blind automation. No client data in public tools. No AI output going out without a human sign-off. That's what <span class="text-gray-700 font-medium">Human Approved</span> means in practice.
            </p>

            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
              <a
                href="/contact"
                class="inline-flex items-center gap-2 px-6 py-3.5 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors shadow-md shadow-brand-200 text-base"
              >
                Book a Free Discovery Call
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
              <a href="/services" class="inline-flex items-center gap-1.5 text-gray-600 font-medium hover:text-brand-600 transition-colors text-sm">
                See how it works
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </a>
            </div>

            <!-- Trust stats -->
            <div class="mt-10 pt-8 border-t border-gray-100 flex flex-wrap gap-8">
              {[
                { stat: "50+", label: "UK businesses helped" },
                { stat: "6", label: "industries covered" },
                { stat: "£0", label: "to start a conversation" },
              ].map((item) => (
                <div class="flex flex-col">
                  <span class="text-2xl font-extrabold text-brand-700">{item.stat}</span>
                  <span class="text-xs text-gray-500 mt-0.5">{item.label}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Hero workflow diagram -->
          <div class="hidden lg:block mt-12 lg:mt-0">
            <svg viewBox="0 0 460 390" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-lg ml-auto" aria-label="AI workflow: current state flows to AI draft, then human review, then saved workflow">
              <defs>
                <marker id="arrowR" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                  <path d="M0,0 L0,6 L6,3 z" fill="#16a34a"/>
                </marker>
                <marker id="arrowD" markerWidth="8" markerHeight="8" refX="3" refY="6" orient="auto">
                  <path d="M0,0 L6,0 L3,6 z" fill="#16a34a"/>
                </marker>
                <marker id="arrowL" markerWidth="8" markerHeight="8" refX="0" refY="3" orient="auto">
                  <path d="M6,0 L6,6 L0,3 z" fill="#16a34a"/>
                </marker>
              </defs>

              <!-- Background -->
              <rect x="10" y="10" width="440" height="370" rx="20" fill="#f0fdf6" stroke="#bbf7d2" stroke-width="1.5"/>

              <!-- Step 1: Current State -->
              <rect x="40" y="45" width="140" height="90" rx="12" fill="white" stroke="#dcfce9" stroke-width="1.5"/>
              <text x="110" y="72" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="11" font-weight="700" fill="#374151">Current State</text>
              <rect x="58" y="82" width="104" height="7" rx="3.5" fill="#e5e7eb"/>
              <rect x="58" y="95" width="84" height="7" rx="3.5" fill="#e5e7eb"/>
              <rect x="58" y="108" width="94" height="7" rx="3.5" fill="#e5e7eb"/>

              <!-- Arrow right -->
              <path d="M183 90 L228 90" stroke="#16a34a" stroke-width="2" stroke-dasharray="5 3" marker-end="url(#arrowR)"/>

              <!-- Step 2: AI Draft -->
              <rect x="232" y="45" width="140" height="90" rx="12" fill="white" stroke="#dcfce9" stroke-width="1.5"/>
              <text x="302" y="72" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="11" font-weight="700" fill="#374151">AI First Draft</text>
              <rect x="250" y="82" width="104" height="7" rx="3.5" fill="#bbf7d2"/>
              <rect x="250" y="95" width="88" height="7" rx="3.5" fill="#bbf7d2"/>
              <rect x="250" y="108" width="96" height="7" rx="3.5" fill="#bbf7d2"/>
              <circle cx="328" cy="62" r="10" fill="#f0fdf6" stroke="#86efad" stroke-width="1"/>
              <text x="328" y="67" text-anchor="middle" font-family="system-ui" font-size="11" fill="#16a34a">✦</text>

              <!-- Arrow down -->
              <path d="M302 138 L302 178" stroke="#16a34a" stroke-width="2" stroke-dasharray="5 3" marker-end="url(#arrowD)"/>

              <!-- Step 3: Human Review -->
              <rect x="232" y="182" width="140" height="90" rx="12" fill="white" stroke="#dcfce9" stroke-width="1.5"/>
              <text x="302" y="208" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="11" font-weight="700" fill="#374151">Human Review</text>
              <circle cx="302" cy="237" r="18" fill="#f0fdf6" stroke="#86efad" stroke-width="1.5"/>
              <path d="M294 237 L300 243 L312 231" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>

              <!-- Arrow left -->
              <path d="M229 227 L184 227" stroke="#16a34a" stroke-width="2" stroke-dasharray="5 3" marker-end="url(#arrowL)"/>

              <!-- Step 4: Saved Workflow -->
              <rect x="40" y="182" width="140" height="90" rx="12" fill="#16a34a"/>
              <text x="110" y="210" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="11" font-weight="700" fill="white">Saved Workflow</text>
              <text x="110" y="226" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="9" fill="#bbf7d2">Prompts · Steps · Owners</text>
              <rect x="78" y="235" width="64" height="28" rx="4" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
              <text x="110" y="253" text-anchor="middle" font-family="system-ui" font-size="11" fill="white">✓ Approved</text>

              <!-- Outcome strip -->
              <rect x="40" y="305" width="380" height="60" rx="12" fill="white" stroke="#dcfce9" stroke-width="1.5"/>
              <text x="230" y="323" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="9" font-weight="600" fill="#9ca3af" letter-spacing="1.5">TYPICAL OUTCOMES</text>
              <text x="100" y="347" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="18" font-weight="800" fill="#15803d">14h</text>
              <text x="100" y="359" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="8" fill="#9ca3af">saved / week</text>
              <line x1="170" y1="330" x2="170" y2="356" stroke="#f3f4f6" stroke-width="1"/>
              <text x="230" y="347" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="18" font-weight="800" fill="#15803d">6 wks</text>
              <text x="230" y="359" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="8" fill="#9ca3af">to real results</text>
              <line x1="295" y1="330" x2="295" y2="356" stroke="#f3f4f6" stroke-width="1"/>
              <text x="360" y="347" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="18" font-weight="800" fill="#15803d">100%</text>
              <text x="360" y="359" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-size="8" fill="#9ca3af">team adoption</text>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- ── THE PROBLEM ───────────────────────────────────────────── -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-12 reveal">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Sound familiar?</h2>
          <p class="text-gray-500 text-lg">You're not behind because you haven't tried. You're behind because nobody gave you a clear path forward.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { icon: "😤", title: "Falling behind competitors", body: "Other businesses in your sector are moving faster. The gap is widening every month — and it shows in bids, response times, and margins." },
            { icon: "💸", title: "Wasted spend on tools", body: "You've paid for AI subscriptions your team opened once and never touched. The problem was never the tool. It was the missing plan." },
            { icon: "🤷", title: "No idea where to start", body: "There's so much noise around AI it's impossible to know what applies to an eight-person accountancy firm or a three-branch estate agency." },
            { icon: "🚧", title: "Team resistance", body: "Staff are sceptical, anxious about their jobs, or just too busy. Getting them to genuinely change how they work feels like pushing a boulder uphill." },
          ].map((p, i) => (
            <div class={`reveal reveal-delay-${i + 1} bg-white rounded-2xl p-6 shadow-sm border border-gray-100`}>
              <div class="text-3xl mb-3">{p.icon}</div>
              <h3 class="font-semibold text-gray-900 mb-2">{p.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{p.body}</p>
            </div>
          ))}
        </div>

        <p class="text-center text-gray-500 mt-8 reveal">
          <span class="font-medium text-gray-700">These are the four things I hear on almost every discovery call.</span> If any of them sound familiar, we should talk.
        </p>
      </div>
    </section>

    <!-- ── SERVICES ──────────────────────────────────────────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-12 reveal">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">How I can help</h2>
          <p class="text-gray-500 text-lg">Three ways to work together — depending on where you are and what you need.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {services.map((s, i) => (
            <a
              href={s.href}
              class={`reveal reveal-delay-${i + 1} group block bg-white border border-gray-200 hover:border-brand-300 rounded-2xl p-7 transition-all hover:shadow-md hover:-translate-y-0.5`}
            >
              <div class="w-12 h-12 rounded-xl bg-brand-50 text-brand-600 flex items-center justify-center mb-4 group-hover:bg-brand-100 transition-colors" set:html={s.icon} />
              <h3 class="font-bold text-gray-900 text-lg mb-2">{s.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed mb-5">{s.description}</p>
              <div class="flex items-center justify-between">
                <span class="text-brand-700 text-sm font-bold bg-brand-50 px-2.5 py-1 rounded-lg">{s.price}</span>
                <span class="inline-flex items-center gap-1 text-brand-600 text-sm font-semibold group-hover:gap-2 transition-all">
                  Learn more
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
        <p class="text-center text-sm text-gray-400 mt-6 reveal">All engagements start with a free discovery call. Scope and price confirmed before anything begins.</p>
      </div>
    </section>

    <!-- ── SOCIAL PROOF ──────────────────────────────────────────── -->
    <section class="py-16 bg-brand-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-center text-brand-300 text-sm font-semibold uppercase tracking-widest mb-10 reveal">What clients say</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {testimonials.map((t, i) => (
            <figure class={`reveal reveal-delay-${i + 1} bg-brand-800 rounded-2xl p-8`}>
              <svg class="w-8 h-8 text-brand-400 mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
              </svg>
              <blockquote class="text-white text-lg leading-relaxed mb-6">"{t.quote}"</blockquote>
              <figcaption class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-brand-600 flex items-center justify-center text-white font-bold text-sm">
                  {t.initials}
                </div>
                <div>
                  <p class="text-white font-semibold text-sm">{t.name}</p>
                  <p class="text-brand-300 text-sm">{t.role}, {t.company}</p>
                </div>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- ── HOW IT WORKS ──────────────────────────────────────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-14 reveal">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">How it works</h2>
          <p class="text-gray-500 text-lg">Three simple steps from "where do I even start?" to a team that's actively using AI every day.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
          <div class="hidden md:block absolute top-10 left-1/4 right-1/4 h-px bg-brand-100 z-0"></div>
          {steps.map((step, i) => (
            <div class={`reveal reveal-delay-${i + 1} relative z-10 text-center`}>
              <div class="w-20 h-20 rounded-2xl bg-brand-50 border-2 border-brand-100 flex items-center justify-center mx-auto mb-5">
                <span class="text-2xl font-extrabold text-brand-600">{step.number}</span>
              </div>
              <h3 class="font-bold text-gray-900 text-lg mb-3">{step.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CASE STUDIES ──────────────────────────────────────────── -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-12 reveal">
          <p class="text-brand-600 font-semibold text-sm uppercase tracking-wider mb-2">Real results</p>
          <h2 class="text-3xl font-bold text-gray-900">What working together actually looks like</h2>
        </div>

        <!-- Case study 1: Accounting -->
        <div class="bg-white rounded-3xl border border-gray-200 overflow-hidden shadow-sm reveal mb-8">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="p-10 lg:p-14">
              <span class="inline-block px-3 py-1 bg-brand-50 text-brand-700 text-xs font-semibold rounded-full mb-6 uppercase tracking-wider">Case Study · Accountancy · London</span>
              <h3 class="text-2xl font-bold text-gray-900 mb-3">Independent accountancy firm, 8 staff</h3>
              <p class="text-gray-500 text-sm font-medium mb-6">AI Workshops + 1:1 Strategy · 90 days</p>
              <div class="space-y-4 mb-8">
                <div>
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">The Challenge</p>
                  <p class="text-gray-700 text-sm leading-relaxed">Partners wanted to adopt AI but feared it would confuse staff or create compliance issues. Three previous attempts to introduce tools had all quietly failed.</p>
                </div>
                <div>
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">What We Did</p>
                  <p class="text-gray-700 text-sm leading-relaxed">A full-day workshop introducing the team to AI tools relevant to their specific roles, followed by a 90-day strategy engagement — GDPR-compliant data handling agreed upfront, human approval step in every workflow.</p>
                </div>
              </div>
              <div class="grid grid-cols-3 gap-4 mb-8">
                {[
                  { stat: "14hrs", label: "saved per week" },
                  { stat: "100%", label: "team adoption" },
                  { stat: "6 wks", label: "to see results" },
                ].map((s) => (
                  <div class="text-center bg-brand-50 rounded-xl p-3">
                    <p class="text-2xl font-extrabold text-brand-700">{s.stat}</p>
                    <p class="text-xs text-gray-500 mt-0.5">{s.label}</p>
                  </div>
                ))}
