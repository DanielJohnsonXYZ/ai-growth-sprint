---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const testimonials = [
  {
    quote: "We went from zero AI adoption to the whole team using it daily in under six weeks. It's saved us at least a day of admin work every week.",
    name: "Sarah Mitchell",
    role: "Director",
    company: "Mitchell & Co Accountants",
  },
  {
    quote: "I'd tried to figure out AI on my own for months. One strategy session with Human Approved AI gave me a clear roadmap. Wish I'd done it sooner.",
    name: "James Okafor",
    role: "Founder",
    company: "Okafor Property Management",
  },
];

const steps = [
  {
    number: "01",
    title: "Free Discovery Call",
    description: "We talk through your business, your team, and your goals. No jargon, no hard sell — just a real conversation to understand where AI can help.",
  },
  {
    number: "02",
    title: "Your Custom Plan",
    description: "Based on your situation, I build a tailored training or consulting plan — the right tools, the right approach, at the right pace for your team.",
  },
  {
    number: "03",
    title: "Training & Ongoing Support",
    description: "We implement together. Your team learns by doing, and I stay available to support adoption, answer questions, and adjust as you grow.",
  },
];

const services = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>`,
    title: "AI Workshops & Team Training",
    description: "Get your whole team using AI confidently — practical, hands-on sessions tailored to your industry and workflows.",
    href: "/services/workshops",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    title: "1:1 Strategy Consulting",
    description: "A trusted AI advisor for your business. We build your roadmap, choose your tools, and work through implementation together.",
    href: "/services/consulting",
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
    title: "AI Audit & Roadmap",
    description: "Not sure where to start? A structured audit of your business uncovers exactly where AI can save time and money.",
    href: "/services/audit",
  },
];
---

<Layout
  title="AI Training & Consulting for Small Businesses"
  description="Human Approved AI helps small and mid-size businesses adopt AI practically and profitably. Book a free discovery call today."
>
  <Header />

  <main>

    <!-- ── HERO ──────────────────────────────────────────────────── -->
    <section class="relative bg-white overflow-hidden pt-16 pb-20 lg:pt-24 lg:pb-32">
      <!-- Background decoration -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full bg-brand-50 opacity-70 blur-3xl"></div>
        <div class="absolute bottom-0 -left-20 w-80 h-80 rounded-full bg-brand-100 opacity-40 blur-3xl"></div>
      </div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-brand-50 border border-brand-100 rounded-full text-brand-700 text-sm font-medium mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-500"></span>
            Practical AI for real businesses
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 tracking-tight leading-tight mb-6">
            Your competitors<br/>
            are using AI.<br/>
            <span class="text-brand-600">Your team isn't. Yet.</span>
          </h1>

          <p class="text-lg sm:text-xl text-gray-600 leading-relaxed max-w-2xl mb-8">
            Human Approved AI helps small and mid-size businesses adopt artificial intelligence — practically, without the jargon, and with results your team will actually use. No theory, no overwhelm, no expensive enterprise consultants.
          </p>

          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a
              href="/contact"
              class="inline-flex items-center gap-2 px-6 py-3.5 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors shadow-md shadow-brand-200 text-base"
            >
              Book a Free Discovery Call
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
            <a href="/services" class="inline-flex items-center gap-1.5 text-gray-600 font-medium hover:text-brand-600 transition-colors text-sm">
              See how it works
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </a>
          </div>

          <!-- Trust signal -->
          <p class="mt-8 text-sm text-gray-400 font-medium">
            Trusted by 50+ small businesses across the UK &nbsp;·&nbsp; No obligation &nbsp;·&nbsp; Jargon-free
          </p>
        </div>
      </div>
    </section>

    <!-- ── THE PROBLEM ───────────────────────────────────────────── -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-12 reveal">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Sound familiar?</h2>
          <p class="text-gray-500 text-lg">You're not behind because you haven't tried. You're behind because nobody gave you a clear path forward.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { icon: "😤", title: "Falling behind competitors", body: "Other businesses in your industry are moving faster. The gap is widening every month." },
            { icon: "💸", title: "Wasted spend on tools", body: "You've paid for AI subscriptions that your team opened once and never used again." },
            { icon: "🤷", title: "No idea where to start", body: "There's so much noise around AI that it's impossible to know what actually applies to your business." },
            { icon: "🚧", title: "Team resistance", body: "Staff are sceptical, anxious, or overwhelmed. Getting them to actually change how they work feels impossible." },
          ].map((p, i) => (
            <div class={`reveal reveal-delay-${i + 1} bg-white rounded-2xl p-6 shadow-sm border border-gray-100`}>
              <div class="text-3xl mb-3">{p.icon}</div>
              <h3 class="font-semibold text-gray-900 mb-2">{p.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{p.body}</p>
            </div>
          ))}
        </div>

        <p class="text-center text-gray-500 mt-8 reveal">
          <span class="font-medium text-gray-700">You're not alone.</span> These are the four most common things I hear from every business owner I speak with.
        </p>
      </div>
    </section>

    <!-- ── SERVICES ──────────────────────────────────────────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-12 reveal">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">How I can help</h2>
          <p class="text-gray-500 text-lg">Three ways to work together — depending on where you are and what you need.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {services.map((s, i) => (
            <a
              href={s.href}
              class={`reveal reveal-delay-${i + 1} group block bg-white border border-gray-200 hover:border-brand-300 rounded-2xl p-7 transition-all hover:shadow-md hover:-translate-y-0.5`}
            >
              <div class="w-12 h-12 rounded-xl bg-brand-50 text-brand-600 flex items-center justify-center mb-4 group-hover:bg-brand-100 transition-colors" set:html={s.icon} />
              <h3 class="font-bold text-gray-900 text-lg mb-2">{s.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed mb-4">{s.description}</p>
              <span class="inline-flex items-center gap-1 text-brand-600 text-sm font-semibold group-hover:gap-2 transition-all">
                Learn more
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── SOCIAL PROOF ──────────────────────────────────────────── -->
    <section class="py-16 bg-brand-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {testimonials.map((t, i) => (
            <figure class={`reveal reveal-delay-${i + 1} bg-brand-800 rounded-2xl p-8`}>
              <svg class="w-8 h-8 text-brand-400 mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
              </svg>
              <blockquote class="text-white text-lg leading-relaxed mb-6">"{t.quote}"</blockquote>
              <figcaption class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-brand-600 flex items-center justify-center text-white font-bold text-sm">
                  {t.name.split(' ').map((n: string) => n[0]).join('')}
                </div>
                <div>
                  <p class="text-white font-semibold text-sm">{t.name}</p>
                  <p class="text-brand-300 text-sm">{t.role}, {t.company}</p>
                </div>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- ── HOW IT WORKS ──────────────────────────────────────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-14 reveal">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">How it works</h2>
          <p class="text-gray-500 text-lg">Three simple steps from "where do I even start?" to a team that's actively using AI every day.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
          <!-- Connector line -->
          <div class="hidden md:block absolute top-10 left-1/4 right-1/4 h-px bg-brand-100 z-0"></div>

          {steps.map((step, i) => (
            <div class={`reveal reveal-delay-${i + 1} relative z-10 text-center`}>
              <div class="w-20 h-20 rounded-2xl bg-brand-50 border-2 border-brand-100 flex items-center justify-center mx-auto mb-5">
                <span class="text-2xl font-extrabold text-brand-600">{step.number}</span>
              </div>
              <h3 class="font-bold text-gray-900 text-lg mb-3">{step.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── FEATURED CASE STUDY ───────────────────────────────────── -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto text-center mb-12 reveal">
          <p class="text-brand-600 font-semibold text-sm uppercase tracking-wider mb-2">Real results</p>
          <h2 class="text-3xl font-bold text-gray-900">What working together actually looks like</h2>
        </div>

        <div class="bg-white rounded-3xl border border-gray-200 overflow-hidden shadow-sm reveal">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="p-10 lg:p-14">
              <span class="inline-block px-3 py-1 bg-brand-50 text-brand-700 text-xs font-semibold rounded-full mb-6 uppercase tracking-wider">Case Study</span>
              <h3 class="text-2xl font-bold text-gray-900 mb-3">Independent accountancy firm, 8 staff</h3>
              <p class="text-gray-500 text-sm font-medium mb-6">London · AI Workshops + 1:1 Strategy</p>

              <div class="space-y-4 mb-8">
                <div>
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">The Challenge</p>
                  <p class="text-gray-700 text-sm leading-relaxed">Partners wanted to adopt AI but feared it would confuse staff or create compliance issues. Three previous attempts to introduce tools had all quietly failed.</p>
                </div>
                <div>
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">What We Did</p>
                  <p class="text-gray-700 text-sm leading-relaxed">A full-day workshop introducing the team to AI tools relevant to their specific roles, followed by a 90-day strategy engagement to embed AI into core workflows.</p>
                </div>
              </div>

              <div class="grid grid-cols-3 gap-4 mb-8">
                {[
                  { stat: "14hrs", label: "saved per week" },
                  { stat: "100%", label: "team adoption" },
                  { stat: "6 wks", label: "to see results" },
                ].map((s) => (
                  <div class="text-center bg-brand-50 rounded-xl p-3">
                    <p class="text-2xl font-extrabold text-brand-700">{s.stat}</p>
                    <p class="text-xs text-gray-500 mt-0.5">{s.label}</p>
                  </div>
                ))}
              </div>

              <a href="/case-studies" class="inline-flex items-center gap-2 text-brand-600 font-semibold text-sm hover:gap-3 transition-all">
                Read the full story
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>

            <div class="bg-brand-700 p-10 lg:p-14 flex flex-col justify-center">
              <svg class="w-10 h-10 text-brand-400 mb-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
              </svg>
              <p class="text-white text-xl leading-relaxed mb-8 font-light">
                "I was genuinely worried about how the team would react. By the end of the workshop, people were actually excited. That was not what I expected. Three months on, I can't imagine going back."
              </p>
              <div>
                <p class="text-white font-semibold">Sarah Mitchell</p>
                <p class="text-brand-300 text-sm">Managing Partner, Mitchell & Co Accountants</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── ABOUT TEASER ──────────────────────────────────────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto flex flex-col md:flex-row items-start gap-10 reveal">
          <!-- Avatar -->
          <div class="flex-shrink-0">
            <div class="w-28 h-28 rounded-2xl bg-brand-100 flex items-center justify-center">
              <svg class="w-14 h-14 text-brand-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
              </svg>
            </div>
          </div>
          <div>
            <p class="text-brand-600 font-semibold text-sm uppercase tracking-wider mb-2">Who I am</p>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">AI expertise without the enterprise price tag</h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              I'm an AI consultant specialising in small and mid-size businesses. I work exclusively with SMBs — not enterprise corporations, not government departments — because I believe smaller businesses deserve access to the same competitive advantages as the big players, without paying big-firm consulting fees or being served a one-size-fits-all programme that doesn't fit their reality.
            </p>
            <p class="text-gray-600 leading-relaxed mb-6">
              My approach is practical, business-first, and human-led. I'm not here to impress you with AI theory. I'm here to help your team work smarter — starting next week.
            </p>
            <a href="/about" class="inline-flex items-center gap-2 text-brand-600 font-semibold text-sm hover:gap-3 transition-all">
              Read my full story
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── FINAL CTA ─────────────────────────────────────────────── -->
    <section class="py-20 bg-brand-700">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">
          Ready to stop watching from the sidelines?
        </h2>
        <p class="text-brand-200 text-lg mb-10 leading-relaxed">
          I take on a limited number of new clients each month. Book a free 30-minute discovery call — no commitment, no hard sell. Just a conversation about what's possible for your business.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white text-brand-700 font-bold rounded-xl hover:bg-brand-50 transition-colors shadow-lg text-base"
        >
          Book a Free Discovery Call
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
        <p class="text-brand-300 text-sm mt-4">30 minutes · No obligation · I reply within 1 business day</p>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
