---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found"
  description="This page is not on Human Approved AI. Try home, services, resources, or contact."
  metaRobots="noindex,follow"
>
  <section class="section section-tight" aria-labelledby="haa-404-title">
    <div class="page-copy">
      <p class="eyebrow">404</p>
      <h1 id="haa-404-title">This page is not here</h1>
      <p class="lead">
        The link may be wrong or the page may have moved. Use one of the paths below to keep going.
      </p>
      <div class="hero-actions" style="margin-top: 28px;">
        <a class="button" href="/" data-cta="404-home">Home</a>
        <a class="button button-secondary" href="/services/" data-cta="404-services">Services</a>
        <a class="button button-secondary" href="/resources/" data-cta="404-resources">Resources</a>
        <a class="button button-secondary" href="/contact/" data-cta="404-contact">Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
