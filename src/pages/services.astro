---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="AI Services for UK SMEs"
  description="Practical AI training, workflow implementation, leadership strategy, and monthly support for UK small and medium businesses."
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">Services</p>
      <h1>AI Services for UK SMEs</h1>
      <p>Practical support for businesses that want results, not hype.</p>
      <a class="button" href="/contact/" data-cta="services-hero-book">Book Free Discovery Call</a>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Not sure where to start?</p>
      <h2>Most businesses start with a free discovery call.</h2>
      <p class="lead">We'll tell you which service fits your business and budget before you commit to anything.</p>
    </aside>
  </section>

  <!-- SERVICE 1: AI TRAINING WORKSHOPS -->
  <section class="section chapter">
    <div class="split">
      <div class="section-header">
        <p class="eyebrow">Service 01</p>
        <h2>AI Training Workshops</h2>
        <p>Hands-on sessions for teams who want to use AI effectively in day-to-day work.</p>
        <ul class="checklist">
          <li>Prompting fundamentals</li>
          <li>Best tools by department</li>
          <li>Time-saving use cases</li>
          <li>Safe usage guidance</li>
        </ul>
        <div class="button-row" style="margin-top: 24px">
          <a class="button" href="/contact/" data-cta="service1-enquire">Enquire</a>
          <a class="button button-secondary" href="/pricing/" data-cta="service1-pricing">See pricing</a>
        </div>
      </div>
      <div class="panel panel-pad">
        <p class="eyebrow">Best for</p>
        <h3>Teams who haven't used AI confidently yet</h3>
        <p>You know AI can help, but the team needs hands-on guidance and clear examples from your actual work — not a tool demo.</p>
        <div class="button-row" style="margin-top: 20px">
          <span class="badge">From £1,500</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE 2: WORKFLOW IMPLEMENTATION -->
  <section class="section">
    <div class="split">
      <div class="panel panel-pad">
        <p class="eyebrow">Best for</p>
        <h3>Businesses losing hours to repetitive work</h3>
        <p>There's admin your team does every day or week that could be done faster. We find it, build the workflow, and hand it over.</p>
        <div class="button-row" style="margin-top: 20px">
          <span class="badge">From £3,500</span>
        </div>
      </div>
      <div class="section-header">
        <p class="eyebrow">Service 02</p>
        <h2>Workflow Implementation</h2>
        <p>We identify repetitive work and improve it using AI systems.</p>
        <ul class="checklist">
          <li>Admin tasks</li>
          <li>Reporting</li>
          <li>Internal knowledge search</li>
          <li>Sales follow-up</li>
          <li>Document workflows</li>
        </ul>
        <div class="button-row" style="margin-top: 24px">
          <a class="button" href="/contact/" data-cta="service2-enquire">Enquire</a>
          <a class="button button-secondary" href="/pricing/" data-cta="service2-pricing">See pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE 3: LEADERSHIP STRATEGY -->
  <section class="section chapter">
    <div class="split">
      <div class="section-header">
        <p class="eyebrow">Service 03</p>
        <h2>Leadership Strategy Sessions</h2>
        <p>For owners and directors who need clarity.</p>
        <ul class="checklist">
          <li>Where AI fits your business</li>
          <li>What to ignore</li>
          <li>ROI opportunities</li>
          <li>Team rollout roadmap</li>
        </ul>
        <div class="button-row" style="margin-top: 24px">
          <a class="button" href="/contact/" data-cta="service3-enquire">Enquire</a>
          <a class="button button-secondary" href="/pricing/" data-cta="service3-pricing">See pricing</a>
        </div>
      </div>
      <div class="panel panel-pad">
        <p class="eyebrow">Best for</p>
        <h3>Owners and directors who need a clear AI strategy</h3>
        <p>You want to understand where AI fits, what you can safely ignore, and what to do first — without being sold software.</p>
        <div class="button-row" style="margin-top: 20px">
          <span class="badge">From £2,500</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE 4: MONTHLY SUPPORT RETAINER -->
  <section class="section">
    <div class="split">
      <div class="panel panel-pad">
        <p class="eyebrow">Best for</p>
        <h3>Businesses who want to stay ahead without hiring internally</h3>
        <p>You've started using AI but want ongoing support, tool updates, and quarterly check-ins to keep momentum.</p>
        <div class="button-row" style="margin-top: 20px">
          <span class="badge">From £1,000/month</span>
        </div>
      </div>
      <div class="section-header">
        <p class="eyebrow">Service 04</p>
        <h2>Monthly Support Retainer</h2>
        <p>Stay ahead without hiring internally.</p>
        <ul class="checklist">
          <li>Ongoing advice</li>
          <li>Team support</li>
          <li>Tool updates</li>
          <li>Quarterly optimisation</li>
        </ul>
        <div class="button-row" style="margin-top: 24px">
          <a class="button" href="/contact/" data-cta="service4-enquire">Enquire</a>
          <a class="button button-secondary" href="/pricing/" data-cta="service4-pricing">See pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section section-tight">
    <div class="panel panel-pad">
      <div class="section-header">
        <h2>Not sure which service fits?</h2>
        <p>Book a free discovery call and we'll point you in the right direction.</p>
      </div>
      <a class="button" href="/contact/" data-cta="services-final-book">Book Free Discovery Call</a>
    </div>
  </section>
</BaseLayout>
