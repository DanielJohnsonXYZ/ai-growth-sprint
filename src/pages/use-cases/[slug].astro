---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getIndustry, SITE, useCases } from "../../data/site";

export function getStaticPaths() {
  return useCases.map((useCase) => ({
    params: { slug: useCase.slug },
    props: { useCase },
  }));
}

const { useCase } = Astro.props;
const relatedIndustries = useCase.relatedIndustries.map((slug: string) => getIndustry(slug)).filter(Boolean);
const schema = {
  "@type": "Service",
  name: `AI training for ${useCase.title.toLowerCase()}`,
  provider: { "@type": "Organization", name: SITE.name, url: SITE.url },
  areaServed: "United Kingdom",
  serviceType: "AI workflow training",
};
---

<BaseLayout title={useCase.metaTitle} description={useCase.metaDescription} schema={schema}>
  <section class="page-hero">
    <div class="page-copy">
      <p class="eyebrow">{useCase.title}</p>
      <h1>{useCase.hero}</h1>
      <p>{useCase.problem}</p>
      <div class="hero-actions">
        <a class="button" href="/contact/" data-cta="use-case-book-a-free-ai-discovery-call">Book a free AI discovery call</a>
        <a class="button button-secondary" href="/">See all industries</a>
      </div>
    </div>
    <aside class="panel panel-pad">
      <p class="eyebrow">Same task, different industries</p>
      <h2>This comes up everywhere.</h2>
      <p class="lead">See how different teams handle the same task with AI — and where human review stays in place.</p>
    </aside>
  </section>

  <section class="section">
    <div class="section-header">
      <p class="eyebrow">Before and after</p>
      <h2>What this looks like in practice.</h2>
    </div>
    <div class="grid grid-3">
      {useCase.examples.map((example) => (
        <article class="card card-featured">
          <p class="eyebrow">{example.industry}</p>
          <div class="data-strip">
            <div><span>Before</span><strong>{example.current}</strong></div>
            <div><span>After</span><strong>{example.ai}</strong></div>
            <div><span>Review</span><strong>{example.review}</strong></div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tight">
    <div class="section-header">
      <p class="eyebrow">Industries where this comes up</p>
      <h2>Same workflow, different teams.</h2>
    </div>
    <div class="grid grid-3">
      {relatedIndustries.map((industry) => (
        <article class="card">
          <h3>{industry?.shortName}</h3>
          <p>{industry?.hero}</p>
          <a href={`/industries/${industry?.slug}/`}>See {industry?.shortName.toLowerCase()} examples</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="panel panel-pad">
      <p class="eyebrow">See the results</p>
      <h2>What teams are seeing so far.</h2>
      <p class="lead">
        Workflow examples and time savings from real teams. Named case studies
        added as they're confirmed — nothing invented.
      </p>
      <a class="button" style="margin-top: 24px" href="/results/">See results</a>
    </div>
  </section>
</BaseLayout>
