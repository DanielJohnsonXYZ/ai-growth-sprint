---
import { industries, SITE, useCases } from "../data/site";
---

<footer class="site-footer">
  <div class="footer-statement">
    <p class="eyebrow">AI Growth Sprint</p>
    <h2>Teach the team to use AI on the work that already eats the week.</h2>
    <p>
      Practical AI workflow training for UK SME teams. No jargon, no theory-only workshops,
      and no fake proof.
    </p>
    <a class="button" href={SITE.bookingUrl}>Book a free 15-minute call</a>
  </div>

  <div class="footer-links" aria-label="Footer navigation">
    <div>
      <h3>Decide</h3>
      <a href="/how-it-works/">How it works</a>
      <a href="/pricing/">Pricing</a>
      <a href="/results/">Results</a>
      <a href="/trust-security/">Trust and security</a>
      <a href="/contact/">Contact</a>
    </div>
    <div>
      <h3>First sectors</h3>
      {industries
        .filter((industry) => industry.outreachPhase === "Phase 1")
        .map((industry) => <a href={`/industries/${industry.slug}/`}>{industry.shortName}</a>)}
    </div>
    <div>
      <h3>Workflows</h3>
      {useCases.slice(0, 4).map((useCase) => <a href={`/use-cases/${useCase.slug}/`}>{useCase.title}</a>)}
    </div>
  </div>
</footer>
