---
import { SITE } from "../data/site";
---

<footer class="site-footer">
  <div class="footer-statement">
    <p class="eyebrow">{SITE.name}</p>
    <h2>Practical AI adoption for UK businesses that want real results, not hype.</h2>
    <p>
      Training, strategy, and implementation support built around how your
      business actually works.
    </p>
    <div class="footer-trust">
      <span>Human-approved outputs</span>
      <span>Plain-English advice</span>
      <span>No product pitches</span>
    </div>
    <div class="button-row">
      <a class="button" href={SITE.bookingUrl} data-cta="footer-book">{SITE.primaryCtaNav}</a>
      <a class="button button-secondary" href="/services/" data-cta="footer-services">See Services</a>
    </div>
  </div>

  <div class="footer-links" aria-label="Footer navigation">
    <div>
      <h3>Services</h3>
      <a href="/services/">All services</a>
      <a href="/pricing/">Pricing</a>
      <a href="/results/">Results</a>
      <a href="/resources/">Resources</a>
      <a href="/contact/">Contact</a>
    </div>
    <div>
      <h3>Company</h3>
      <a href="/about/">About</a>
      <a href="/industries/">Industries</a>
      <a href="/contact/">Book a call</a>
      <a href="/privacy/">Privacy</a>
      <a href="/trust-security/">Trust &amp; security</a>
      <a href="/ai-policy-template/">AI policy sample</a>
    </div>
    <div>
      <h3>Industries</h3>
      <a href="/industries/accounting/">Accounting</a>
      <a href="/industries/recruitment/">Recruitment</a>
      <a href="/industries/construction/">Construction</a>
      <a href="/industries/legal/">Legal</a>
      <a href="/industries/property/">Property</a>
      <a href="/industries/manufacturing/">Manufacturing</a>
    </div>
  </div>

  <div class="footer-legal-meta">
    <p>
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      {SITE.linkedInUrl ? (
        <>
          {" · "}
          <a href={SITE.linkedInUrl} rel="noopener noreferrer" target="_blank">LinkedIn</a>
        </>
      ) : null}
    </p>
    <nav class="footer-legal-nav" aria-label="Legal and policies">
      <a href="/privacy/">Privacy</a>
      <a href="/privacy/#cookies">Cookies</a>
      <a href="/terms/">Terms of use</a>
      <a href="/trust-security/">Trust &amp; security</a>
      <a href="/faq/">FAQ</a>
    </nav>
  </div>
</footer>
