---
import { industries, SITE, useCases } from "../data/site";
---

<footer class="site-footer">
  <div class="footer-statement">
    <p class="eyebrow">{SITE.name}</p>
    <h2>Make AI adoption safe, useful, and hard to forget.</h2>
    <p>
      Practical AI workflow training for 10-50 person UK SME teams. No jargon,
      no reckless shortcuts, and no fake proof.
    </p>
    <div class="footer-trust">
      <span>AI prepares. People approve.</span>
      <span>Construction, accounting, and property first.</span>
      <span>Proof labelled until approved.</span>
    </div>
    <div class="button-row">
      <a class="button" href={SITE.bookingUrl}>Book a free 15-minute call</a>
      <a class="button button-secondary" href="/trust-security/">Read trust rules</a>
    </div>
  </div>

  <div class="footer-links" aria-label="Footer navigation">
    <div>
      <h3>Decide</h3>
      <a href="/how-it-works/">How it works</a>
      <a href="/pricing/">Pricing</a>
      <a href="/results/">Results</a>
      <a href="/trust-security/">Trust and security</a>
      <a href="/contact/">Contact</a>
    </div>
    <div>
      <h3>First sectors</h3>
      {industries
        .filter((industry) => industry.outreachPhase === "Phase 1")
        .map((industry) => <a href={`/industries/${industry.slug}/`}>{industry.shortName}</a>)}
    </div>
    <div>
      <h3>Workflows</h3>
      {useCases.slice(0, 4).map((useCase) => <a href={`/use-cases/${useCase.slug}/`}>{useCase.title}</a>)}
    </div>
  </div>
</footer>
