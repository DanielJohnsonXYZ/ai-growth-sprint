---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../data/site";

type Props = {
  title: string;
  description?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  metaRobots?: string;
};

const { title, description = SITE.description, schema = [], metaRobots = "index,follow,max-image-preview:large" } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const ogImageUrl = `${SITE.url}/og-image.png`;
const schemas = Array.isArray(schema) ? schema : [schema];
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
};

// Build BreadcrumbList from pathname (skip for homepage)
const segments = Astro.url.pathname.replace(/\/$/, "").split("/").filter(Boolean);
const breadcrumbSchema = segments.length > 0 ? {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: new URL("/", SITE.url).toString() },
    ...segments.map((seg, i) => ({
      "@type": "ListItem",
      position: i + 2,
      name: seg.split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" "),
      item: new URL("/" + segments.slice(0, i + 1).join("/") + "/", SITE.url).toString(),
    })),
  ],
} : null;

const schemaGraph = [organizationSchema, breadcrumbSchema, ...schemas].filter(Boolean);
const pageTitle = title.includes(SITE.name) ? title : `${title} | ${SITE.name}`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f766e" />
    <!-- Analytics: GTM high in head; dataLayer — page_context; cta_click; booking_click; calendly_click; form_submit; resource_download. GA4 Config tag + triggers in GTM workspace. -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    {SITE.gtmContainerId ? (
      <script
        is:inline
        set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${SITE.gtmContainerId}');`}
      />
    ) : null}
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={metaRobots} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={pageTitle} />
    <meta name="ai:summary" content={description} />
    <meta name="ai:role" content="Practical AI training and adoption support for UK SME teams" />
    <meta name="ai:serves" content="UK SMEs adopting AI with human-in-the-loop workflows" />
    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph.length === 1 ? schemaGraph[0] : { "@context": "https://schema.org", "@graph": schemaGraph })} />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "page_context",
        page_path: window.location.pathname,
        page_title: document.title,
        page_location: window.location.href
      });

      document.addEventListener("click", (event) => {
        const target = event.target;
        const link = target instanceof Element ? target.closest("a") : null;
        if (!link) return;
        const label = link.dataset.cta || link.textContent?.trim();
        if (!label) return;
        const href = link.href || "";
        const isCalendly = href.includes("calendly.com");
        let eventName = label.toLowerCase().includes("book") ? "booking_click" : "cta_click";
        if (isCalendly) eventName = "calendly_click";
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: eventName,
          cta_label: label,
          cta_href: href,
          page_path: window.location.pathname
        });
      });

      document.addEventListener("click", (event) => {
        const target = event.target;
        const link = target instanceof Element ? target.closest("a[download]") : null;
        if (!link) return;
        const href = link.href || "";
        const label = link.dataset.cta || link.textContent?.trim() || "resource_download";
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "resource_download",
          download_url: href,
          download_label: label,
          page_path: window.location.pathname
        });
      });

      document.addEventListener("submit", (event) => {
        const form = event.target;
        if (!(form instanceof HTMLFormElement)) return;
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "form_submit",
          form_id: form.id || form.name || "unknown",
          form_action: form.action || "unknown",
          page_path: window.location.pathname
        });
      });
    </script>
  </head>
  <body>
    {SITE.gtmContainerId ? (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${SITE.gtmContainerId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
          title="Google Tag Manager"
        />
      </noscript>
    ) : null}
    <div class="grain"></div>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --ink: #101926;
    --muted: #485568;
    --paper: #f7faf8;
    --paper-soft: #ffffff;
    --surface: rgba(255, 255, 255, 0.84);
    --surface-strong: #e9f3f0;
    --surface-rule: #d7e7e2;
    --moss: #0f766e;
    --moss-2: #12383f;
    --cta: #101926;
    --clay: #d05b45;
    --amber: #e8b84d;
    --lime: #90b76d;
    --line: rgba(16, 25, 38, 0.22);
    --line-strong: rgba(16, 25, 38, 0.5);
    --shadow: 0 20px 46px rgba(16, 25, 38, 0.12);
    --shadow-hard: 5px 5px 0 rgba(208, 91, 69, 0.9);
    --radius: 12px;
    --radius-small: 8px;
    --space-3: 24px;
    --space-4: 32px;
    --space-5: 48px;
    --section-space: 84px;
    --max: 1180px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    color: var(--ink);
    background: var(--paper);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 18px;
    line-height: 1.6;
    background:
      radial-gradient(circle at top left, rgba(232, 184, 77, 0.2), transparent 34rem),
      radial-gradient(circle at 85% 8%, rgba(15, 118, 110, 0.13), transparent 28rem),
      linear-gradient(135deg, #f7faf8 0%, #ffffff 52%, #edf6f3 100%);
  }

  .grain {
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 0;
    opacity: 0.2;
    background-image:
      linear-gradient(rgba(16, 25, 38, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(16, 25, 38, 0.035) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: linear-gradient(to bottom, black, transparent 90%);
  }

  body > *:not(.grain) {
    position: relative;
    z-index: 1;
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 9999;
    padding: 12px 24px;
    background: var(--ink);
    color: var(--amber);
    font-weight: 700;
    text-decoration: none;
    border-radius: 0 0 var(--radius-small) 0;
  }

  .skip-link:focus {
    left: 0;
  }

  .brand:focus-visible,
  nav a:focus-visible,
  .button:focus-visible,
  .button-secondary:focus-visible {
    outline: 3px solid var(--amber);
    outline-offset: 3px;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    line-height: 1.05;
    letter-spacing: 0;
  }

  h1 {
    font-size: clamp(2.65rem, 5.7vw, 5.35rem);
  }

  h2 {
    font-size: clamp(2.4rem, 5vw, 5rem);
  }

  h3 {
    font-size: clamp(1.45rem, 2.2vw, 2.2rem);
  }

  p {
    margin: 0;
  }

  main {
    overflow: hidden;
  }

  .site-header,
  .site-footer,
  .section,
  .hero,
  .page-hero {
    width: min(var(--max), calc(100% - 32px));
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border: 2px solid var(--ink);
    border-radius: 10px;
    background: var(--surface-strong);
    font-weight: 700;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand small {
    color: var(--muted);
    font-size: 0.78rem;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 18px;
    color: var(--muted);
    font-size: 0.96rem;
  }

  nav a {
    text-decoration: none;
  }

  nav a:hover {
    color: var(--ink);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: max-content;
    max-width: 100%;
    min-height: 52px;
    padding: 0 22px;
    border: 2px solid var(--cta);
    border-radius: 8px;
    background: var(--cta);
    color: var(--paper-soft);
    font-weight: 700;
    text-decoration: none;
    box-shadow: var(--shadow-hard);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .button:hover {
    transform: translate(3px, 3px);
    box-shadow: 3px 3px 0 var(--clay);
  }

  .button-secondary {
    background: var(--paper-soft);
    color: var(--ink);
    box-shadow: none;
    border-color: var(--line-strong);
    font-weight: 700;
  }

  .button-secondary:hover {
    transform: translateY(-1px);
    box-shadow: none;
    background: var(--surface-strong);
  }

  .button-small {
    min-height: 44px;
    padding: 0 18px;
    font-size: 0.92rem;
  }

  .hero,
  .page-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(360px, 0.9fr);
    gap: clamp(40px, 6vw, 72px);
    align-items: center;
    padding: 56px 0 46px;
  }

  .page-hero {
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 0.7fr);
    padding-bottom: var(--space-5);
    align-items: start;
  }

  .hero-copy,
  .page-copy {
    display: grid;
    gap: var(--space-4);
  }

  .hero-copy p,
  .page-copy p,
  .lead {
    max-width: 780px;
    color: var(--muted);
    font-size: clamp(1.16rem, 1.8vw, 1.42rem);
  }

  .hero-copy h1 {
    max-width: 12.8ch;
  }

  .hero-copy > p:not(.eyebrow) {
    max-width: 620px;
  }

  .eyebrow {
    color: var(--clay);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .hero-actions,
  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  .panel {
    border: 2px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .panel-pad {
    padding: clamp(24px, 4vw, 48px);
  }

  .proof-meter {
    position: relative;
    display: grid;
    gap: var(--space-3);
    border-color: var(--ink);
    background: linear-gradient(145deg, var(--surface-strong), var(--paper-soft));
    box-shadow: var(--shadow);
  }

  .proof-meter::before {
    content: "HUMAN SIGN-OFF";
    display: inline-flex;
    width: max-content;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border: 2px solid var(--ink);
    border-radius: 8px;
    background: var(--amber);
    color: var(--ink);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
  }

  .proof-meter h2 {
    font-size: clamp(1.85rem, 3.3vw, 3.1rem);
  }

  .stat-stack {
    display: grid;
    gap: 12px;
  }

  .stat-stack div {
    display: grid;
    gap: 6px;
    padding: 16px 18px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-small);
    background: rgba(255, 255, 255, 0.78);
  }

  .stat-stack span {
    color: var(--clay);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .stat-stack strong {
    font-family: "Fraunces", Georgia, serif;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    line-height: 1.05;
  }

  .proof-note {
    color: var(--muted);
    font-size: 1rem;
  }

  .section {
    padding: 76px 0;
    border-bottom: 1px solid var(--line);
  }

  .section:last-of-type {
    border-bottom: none;
  }

  .section-tight {
    padding: 56px 0;
    border-bottom: 1px solid var(--line);
  }

  .section-tight:last-of-type {
    border-bottom: none;
  }

  .chapter {
    padding: clamp(40px, 6vw, 72px);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.56);
  }

  .hero-proof-after {
    padding-top: 40px;
    padding-bottom: 48px;
  }

  .hero-proof-strip-wrap {
    padding-top: 28px;
    padding-bottom: 36px;
    border-bottom: none;
  }

  .hero-proof-strip-tagline {
    margin-top: 18px;
    text-align: center;
    max-width: 920px;
    margin-inline: auto;
  }

  .trust-ribbon {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    align-items: center;
    padding: 24px 28px;
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
  }

  .trust-ribbon p {
    max-width: 760px;
    color: var(--muted);
    font-size: 1.04rem;
  }

  .section-header {
    display: grid;
    gap: 12px;
    max-width: 760px;
    margin-bottom: 36px;
  }

  .section-header p {
    color: var(--muted);
    font-size: 1.08rem;
  }

  .grid {
    display: grid;
    gap: var(--space-3);
  }

  .grid-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .grid-4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .card {
    display: grid;
    gap: 14px;
    align-content: start;
    min-height: 100%;
    padding: 26px;
    border: 1px solid var(--line);
    border-radius: var(--radius-small);
    background: var(--surface);
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .card-featured {
    padding: 30px;
    border: 2px solid var(--ink);
    background: var(--surface-strong);
  }

  .card-quiet {
    background: rgba(255, 249, 236, 0.52);
  }

  .card strong {
    font-size: 1.08rem;
  }

  .card p,
  .card li {
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.72;
  }

  .card a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: max-content;
    font-weight: 700;
    font-size: 0.96rem;
    color: var(--moss);
    text-decoration-thickness: 2px;
    text-underline-offset: 5px;
  }

  .card a::after {
    content: "->";
    color: var(--clay);
    text-decoration: none;
    transition: transform 160ms ease;
  }

  .card a:hover::after {
    transform: translateX(3px);
  }

  .card-interactive:hover {
    transform: translateY(-4px);
    border-color: var(--ink);
    background: var(--paper-soft);
  }

  .highlight {
    background: linear-gradient(145deg, var(--moss), var(--moss-2));
    color: var(--paper-soft);
    border: 2px solid rgba(23, 33, 29, 0.7);
  }

  .highlight p,
  .highlight li {
    color: rgba(255, 249, 236, 0.78);
  }

  .highlight .eyebrow {
    color: var(--amber);
  }

  .highlight .mini-proof {
    padding-top: 12px;
    border-top: 1px solid rgba(255, 249, 236, 0.22);
    color: rgba(255, 249, 236, 0.9);
    font-weight: 700;
  }

  .highlight a {
    color: var(--paper-soft);
  }

  .highlight a::after {
    color: var(--amber);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 13px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: var(--paper-soft);
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: var(--space-5);
    align-items: start;
  }

  .workflow {
    display: grid;
    gap: var(--space-3);
  }

  .workflow-row {
    display: grid;
    grid-template-columns: 0.75fr 1fr 1fr 0.75fr;
    gap: var(--space-3);
    padding: var(--space-3);
    border: 1px solid var(--line);
    border-radius: var(--radius-small);
    background: var(--surface);
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
  }

  .workflow-row:hover {
    transform: translateY(-3px);
    border-color: var(--ink);
    background: var(--paper-soft);
  }

  .workflow-row > div {
    display: grid;
    align-content: start;
    gap: 8px;
    padding-left: 14px;
    border-left: 2px solid var(--line);
  }

  .workflow-row > div:first-child {
    padding-left: 0;
    border-left: 0;
  }

  .workflow-row strong {
    font-family: "Fraunces", Georgia, serif;
    font-size: 1.35rem;
    line-height: 1.05;
  }

  .workflow-row p {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .checklist {
    display: grid;
    gap: 12px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .checklist li {
    padding-left: 28px;
    position: relative;
    color: var(--muted);
  }

  .checklist li::before {
    content: "";
    position: absolute;
    top: 0.55em;
    left: 0;
    width: 12px;
    height: 12px;
    border: 2px solid var(--ink);
    border-radius: 50%;
    background: var(--lime);
  }

  .site-footer {
    display: grid;
    gap: var(--space-5);
    padding: 76px 0 56px;
    border-top: 3px solid var(--ink);
  }

  .footer-statement {
    display: grid;
    gap: 18px;
    max-width: 860px;
  }

  .footer-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .footer-trust span {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0 12px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: var(--paper-soft);
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .site-footer p {
    max-width: 680px;
    margin: 0;
    color: var(--muted);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    max-width: 860px;
  }

  .footer-links div {
    display: grid;
    align-content: start;
    gap: 10px;
  }

  .footer-links h3 {
    font-size: 1.2rem;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--ink);
  }

  .footer-legal-meta {
    display: grid;
    gap: 12px;
    padding-top: 8px;
    border-top: 1px solid var(--line);
    max-width: 860px;
  }

  .footer-legal-meta p {
    margin: 0;
    font-size: 0.95rem;
  }

  .footer-legal-nav {
