---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../data/site";

type Props = {
  title: string;
  description?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
};

const { title, description = SITE.description, schema = [] } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const schemas = Array.isArray(schema) ? schema : [schema];
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
};

// Build BreadcrumbList from pathname (skip for homepage)
const segments = Astro.url.pathname.replace(/\/$/, "").split("/").filter(Boolean);
const breadcrumbSchema = segments.length > 0 ? {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: new URL("/", SITE.url).toString() },
    ...segments.map((seg, i) => ({
      "@type": "ListItem",
      position: i + 2,
      name: seg.split("-").map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(" "),
      item: new URL("/" + segments.slice(0, i + 1).join("/") + "/", SITE.url).toString(),
    })),
  ],
} : null;

const schemaGraph = [organizationSchema, breadcrumbSchema, ...schemas].filter(Boolean);
const pageTitle = title.includes(SITE.name) ? title : `${title} | ${SITE.name}`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {/* TODO: Create a real OG image before launch */}
    <meta property="og:image" content={`${SITE.url}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&family=Fraunces:opsz,wght@9..144,500;9..144,700;9..144,850&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(schemaGraph.length === 1 ? schemaGraph[0] : { "@context": "https://schema.org", "@graph": schemaGraph })} />
  </head>
  <body>
    <div class="grain"></div>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --ink: #17211d;
    --muted: #5f675f;
    --paper: #f7f0df;
    --paper-soft: #fff9ec;
    --surface: rgba(255, 249, 236, 0.76);
    --surface-strong: #efe1c2;
    --surface-rule: #d7c5a3;
    --moss: #244d3e;
    --moss-2: #1a392f;
    --cta: #101713;
    --clay: #bd6137;
    --amber: #edc86a;
    --lime: #bedf71;
    --line: rgba(23, 33, 29, 0.18);
    --line-strong: rgba(23, 33, 29, 0.44);
    --shadow: 0 22px 52px rgba(36, 77, 62, 0.16);
    --shadow-hard: 10px 10px 0 rgba(23, 33, 29, 0.16);
    --radius: 22px;
    --radius-small: 14px;
    --space-3: 24px;
    --space-4: 32px;
    --space-5: 48px;
    --section-space: 96px;
    --max: 1180px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    color: var(--ink);
    background: var(--paper);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: "Atkinson Hyperlegible", Verdana, sans-serif;
    font-size: 18px;
    line-height: 1.6;
    background:
      radial-gradient(circle at top left, rgba(237, 200, 106, 0.44), transparent 36rem),
      radial-gradient(circle at 85% 10%, rgba(190, 223, 113, 0.24), transparent 28rem),
      linear-gradient(135deg, #f7f0df 0%, #fff8e8 48%, #e8efe1 100%);
  }

  .grain {
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 0;
    opacity: 0.2;
    background-image:
      linear-gradient(rgba(23, 33, 29, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(23, 33, 29, 0.035) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: linear-gradient(to bottom, black, transparent 90%);
  }

  body > *:not(.grain) {
    position: relative;
    z-index: 1;
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 9999;
    padding: 12px 24px;
    background: var(--ink);
    color: var(--amber);
    font-weight: 700;
    text-decoration: none;
    border-radius: 0 0 var(--radius-small) 0;
  }

  .skip-link:focus {
    left: 0;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family: "Fraunces", Georgia, serif;
    line-height: 1.05;
    letter-spacing: -0.055em;
  }

  h1 {
    font-size: clamp(3.4rem, 8vw, 7.8rem);
  }

  h2 {
    font-size: clamp(2.4rem, 5vw, 5rem);
  }

  h3 {
    font-size: clamp(1.45rem, 2.2vw, 2.2rem);
  }

  p {
    margin: 0;
  }

  main {
    overflow: hidden;
  }

  .site-header,
  .site-footer,
  .section,
  .hero,
  .page-hero {
    width: min(var(--max), calc(100% - 32px));
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border: 2px solid var(--ink);
    border-radius: 50%;
    background: var(--amber);
    font-weight: 700;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand small {
    color: var(--muted);
    font-size: 0.78rem;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 18px;
    color: var(--muted);
    font-size: 0.93rem;
  }

  nav a {
    text-decoration: none;
  }

  nav a:hover {
    color: var(--ink);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 52px;
    padding: 0 22px;
    border: 2px solid var(--cta);
    border-radius: 999px;
    background: var(--cta);
    color: var(--paper-soft);
    font-weight: 700;
    text-decoration: none;
    box-shadow: 7px 7px 0 var(--clay);
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .button:hover {
    transform: translate(3px, 3px);
    box-shadow: 3px 3px 0 var(--clay);
  }

  .button-secondary {
    background: var(--paper-soft);
    color: var(--ink);
    box-shadow: none;
  }

  .button-small {
    min-height: 44px;
    padding: 0 18px;
    font-size: 0.92rem;
  }

  .hero,
  .page-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: var(--space-5);
    align-items: start;
    padding: var(--section-space) 0 64px;
  }

  .page-hero {
    grid-template-columns: minmax(0, 0.9fr) minmax(300px, 0.7fr);
    padding-bottom: var(--space-5);
  }

  .hero-copy,
  .page-copy {
    display: grid;
    gap: var(--space-3);
  }

  .hero-copy p,
  .page-copy p,
  .lead {
    max-width: 760px;
    color: var(--muted);
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
  }

  .eyebrow {
    color: var(--clay);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .hero-actions,
  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  .panel {
    border: 2px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .panel-pad {
    padding: clamp(24px, 4vw, 48px);
  }

  .proof-meter {
    position: relative;
    display: grid;
    gap: var(--space-3);
    border-color: var(--ink);
    background: var(--surface-rule);
    box-shadow: var(--shadow-hard);
  }

  .proof-meter::before {
    content: "SYSTEM RULE";
    display: inline-flex;
    width: max-content;
    min-height: 30px;
    align-items: center;
    padding: 0 12px;
    border: 2px solid var(--ink);
    border-radius: 999px;
    background: var(--amber);
    color: var(--ink);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
  }

  .meter-row {
    display: grid;
    gap: 8px;
  }

  .meter-row span {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .meter {
    height: 16px;
    border: 2px solid var(--ink);
    border-radius: 999px;
    background: var(--paper);
    overflow: hidden;
  }

  .meter i {
    display: block;
    height: 100%;
    background: linear-gradient(90deg, var(--clay), var(--amber), var(--lime));
  }

  .section {
    padding: var(--section-space) 0;
  }

  .section-tight {
    padding: 64px 0;
  }

  .section-header {
    display: grid;
    gap: 16px;
    max-width: 760px;
    margin-bottom: var(--space-5);
  }

  .section-header p {
    color: var(--muted);
    font-size: 1.12rem;
  }

  .grid {
    display: grid;
    gap: var(--space-3);
  }

  .grid-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .grid-4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .card {
    display: grid;
    gap: 16px;
    align-content: start;
    min-height: 100%;
    padding: var(--space-3);
    border: 1px solid var(--line);
    border-radius: var(--radius-small);
    background: var(--surface);
  }

  .card-featured {
    padding: var(--space-4);
    border: 2px solid var(--ink);
    background: var(--surface-strong);
    box-shadow: var(--shadow-hard);
  }

  .card strong {
    font-size: 1.04rem;
  }

  .card p,
  .card li {
    color: var(--muted);
  }

  .card a {
    font-weight: 700;
    color: var(--moss);
    text-decoration-thickness: 2px;
    text-underline-offset: 5px;
  }

  .highlight {
    background: var(--moss);
    color: var(--paper-soft);
    border: 2px solid var(--moss-2);
    box-shadow: var(--shadow-hard);
  }

  .highlight p,
  .highlight li {
    color: rgba(255, 249, 236, 0.78);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 13px;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    background: var(--paper-soft);
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: var(--space-5);
    align-items: start;
  }

  .workflow {
    display: grid;
    gap: var(--space-3);
  }

  .workflow-row {
    display: grid;
    grid-template-columns: 0.75fr 1fr 1fr 0.75fr;
    gap: var(--space-3);
    padding: var(--space-3);
    border: 1px solid var(--line);
    border-radius: var(--radius-small);
    background: var(--surface);
  }

  .workflow-row > div {
    display: grid;
    align-content: start;
    gap: 8px;
    padding-left: 14px;
    border-left: 2px solid var(--line);
  }

  .workflow-row > div:first-child {
    padding-left: 0;
    border-left: 0;
  }

  .workflow-row strong {
    font-family: "Fraunces", Georgia, serif;
    font-size: 1.35rem;
    line-height: 1.05;
  }

  .workflow-row p {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .checklist {
    display: grid;
    gap: 12px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .checklist li {
    padding-left: 28px;
    position: relative;
    color: var(--muted);
  }

  .checklist li::before {
    content: "";
    position: absolute;
    top: 0.55em;
    left: 0;
    width: 12px;
    height: 12px;
    border: 2px solid var(--ink);
    border-radius: 50%;
    background: var(--lime);
  }

  .site-footer {
    display: grid;
    gap: var(--space-5);
    padding: 72px 0 56px;
    border-top: 3px solid var(--ink);
  }

  .footer-statement {
    display: grid;
    gap: 18px;
    max-width: 860px;
  }

  .site-footer p {
    max-width: 680px;
    margin: 0;
    color: var(--muted);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    max-width: 860px;
  }

  .footer-links div {
    display: grid;
    align-content: start;
    gap: 10px;
  }

  .footer-links h3 {
    font-size: 1.2rem;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--ink);
  }

  .pending {
    border: 1px dashed var(--clay);
    background: rgba(189, 97, 55, 0.1);
    color: var(--clay);
  }

  .flow-cue {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    border: 2px solid var(--ink);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface-strong);
  }

  .flow-cue > * {
    position: relative;
    display: grid;
    gap: 8px;
    min-height: 150px;
    padding: var(--space-3);
    border-right: 2px solid var(--ink);
  }

  .flow-cue > *::after {
    content: "->";
    position: absolute;
    right: 18px;
    top: 18px;
    color: var(--clay);
    font-weight: 700;
  }

  .flow-cue > *:last-child {
    border-right: 0;
  }

  .flow-cue > *:last-child::after {
    content: "";
  }

  .data-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border: 2px solid var(--ink);
    border-radius: var(--radius-small);
    background: var(--ink);
  }

  .data-strip div {
    display: grid;
    gap: 6px;
    padding: 18px;
    background: var(--paper-soft);
  }

  .data-strip span {
    color: var(--clay);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .data-strip strong {
    font-size: 1rem;
  }

  @media (max-width: 980px) {
    .site-header > nav {
      display: none;
    }

    .hero,
    .page-hero,
    .split,
    .site-footer {
      grid-template-columns: 1fr;
    }

    .grid-3,
    .grid-4,
    .flow-cue,
    .data-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .workflow-row {
      grid-template-columns: 1fr;
    }

    .workflow-row > div {
      padding-left: 0;
      padding-top: 14px;
      border-left: 0;
      border-top: 2px solid var(--line);
    }

    .workflow-row > div:first-child {
      padding-top: 0;
      border-top: 0;
    }
  }

  @media (max-width: 640px) {
    body {
      font-size: 16px;
    }

    .site-header {
      align-items: flex-start;
    }

    .site-header .button {
      display: none;
    }

    .hero,
    .page-hero {
      padding-top: 36px;
    }

    .grid-2,
    .grid-3,
    .grid-4,
    .flow-cue,
    .data-strip,
    .footer-links {
      grid-template-columns: 1fr;
    }

    .card,
    .panel-pad {
      padding: 22px;
    }
  }
</style>
